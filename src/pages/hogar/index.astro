---
import ShopLayout from '~/layouts/ShopLayout.astro';
import ScrollyHero from '~/components/hogar/ScrollyHero.astro';
import FindUs from '~/components/widgets/FindUs.astro';
import SupportOverview from '~/components/widgets/SupportOverview.astro';
import ProductMarqueeShowcase from '~/components/widgets/ProductMarqueeShowcase.astro';
import ProductCard from '~/components/hogar/ProductCard.astro';
import { Icon } from 'astro-icon/components';

import { medusaClient } from '~/lib/medusa';

const metadata = {
  title: 'Hogar',
  description: 'Una línea pensada para cocina casera y pequeños emprendimientos, disponible próximamente.',
};

interface MedusaProduct {
  id: string;
  title: string;
  handle: string;
  description?: string;
  thumbnail?: string | null;
  variants?: Array<{ title: string }>;
}

// Obtenemos los productos de Medusa (Frontend Store API)
let medusaProducts: MedusaProduct[] = [];
let fetchError: string | null = null;
try {
  const { products } = await medusaClient.store.product.list({
    limit: 10,
    fields: '*variants'
  });
  medusaProducts = products;
} catch (error) {
  console.error("Error conectando a MedusaJS:", error);
  fetchError = "No se pudo conectar a la tienda en vivo. Mostrando catálogo estático.";
}
---

<ShopLayout metadata={metadata}>
  <ScrollyHero />

  <ProductMarqueeShowcase
    title="Próximamente para tu cocina"
    subtitle="Una selección creada para acompañar recetas caseras con la calidad y el equilibrio de Deiman."
    showCta={false}
  />

  <section id="catalogo" class="py-12 md:py-16">
    <div class="mx-auto w-full max-w-5xl px-6">
      <div class="grid gap-8 md:grid-cols-3">
        <div id="sabores" class="rounded-2xl border border-gray-200 bg-white/80 p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-gray-900">Sabores para el hogar</h2>
          <p class="mt-3 text-sm text-gray-600">
            Una selección pensada para recetas caseras y pequeños emprendimientos, con perfiles suaves y fáciles de
            usar. Próximamente disponible.
          </p>
        </div>
        <div id="colores" class="rounded-2xl border border-gray-200 bg-white/80 p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-gray-900">Colores</h2>
          <p class="mt-3 text-sm text-gray-600">
            Tonalidades estables para dar vida a masas, bebidas y preparaciones artesanales sin complicaciones.
          </p>
        </div>
        <div id="sazonadores" class="rounded-2xl border border-gray-200 bg-white/80 p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-gray-900">Sazonadores</h2>
          <p class="mt-3 text-sm text-gray-600">
            Mezclas equilibradas que realzan recetas saladas y snacks, listas para facilitar tu producción diaria.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* SECCIÓN DE CATÁLOGO MEDUSA JS */}
  <section class="py-16 bg-slate-50 border-t border-b border-gray-200">
    <div class="mx-auto w-full max-w-7xl px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight sm:text-4xl">
          Nuestros Productos
        </h2>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
          Calidad profesional de Deiman, ahora disponible para tu hogar.
        </p>
      </div>
      
      {fetchError ? (
        <div class="p-6 bg-red-50 text-red-700 rounded-2xl border border-red-100 flex flex-col items-center justify-center text-center">
          <Icon name="tabler:alert-circle" class="w-12 h-12 mb-4 text-red-400" />
          <h3 class="text-lg font-bold mb-2">Error de Conexión</h3>
          <p>{fetchError}</p> 
          <span class="text-sm mt-2 opacity-80">¿Aseguraste agregar productos al panel y asignarles el *Default Sales Channel*?</span>
        </div>
      ) : medusaProducts.length === 0 ? (
        <div class="p-6 bg-yellow-50 text-yellow-800 rounded-2xl border border-yellow-100 flex flex-col items-center justify-center text-center">
          <Icon name="tabler:basket-x" class="w-12 h-12 mb-4 text-yellow-500" />
          <h3 class="text-lg font-bold mb-2">Catálogo Vacío</h3>
          <p>La conexión a la tienda es exitosa, pero no hay productos publicados.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 xl:gap-8">
          {medusaProducts.map(p => (
            <ProductCard product={p} />
          ))}
        </div>
      )}
    </div>
  </section>

  <FindUs />

  <SupportOverview />
</ShopLayout>
