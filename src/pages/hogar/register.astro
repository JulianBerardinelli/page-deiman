---
import ShopLayout from '~/layouts/ShopLayout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = false;
---

<ShopLayout metadata={{ title: 'Registrarse | Deiman' }}>
  <div class="min-h-[calc(100vh-70px)] flex-grow w-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-[url('/images/backgrounds/hogar.jpg')] bg-cover bg-center bg-no-repeat relative overflow-hidden">
     <!-- Capa oscura para legibilidad -->
     <div class="absolute inset-0 bg-black/20"></div>
     <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[100px] pointer-events-none"></div>
     <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-green-500/10 rounded-full blur-[100px] pointer-events-none"></div>

     <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-3xl shadow-2xl border border-gray-100 relative z-10">
       <div>
         <h2 class="mt-2 text-center text-3xl font-black text-gray-900 tracking-tight">
           Crea tu cuenta
         </h2>
         <p class="mt-3 text-center text-sm text-gray-500">
           Únete a Deiman para gestionar tus pedidos fácilmente.
         </p>
       </div>
       
       <form id="register-form" class="mt-8 space-y-6">
         <div class="rounded-md shadow-sm space-y-4">
           
           <div class="grid grid-cols-2 gap-4">
               <div>
                 <label for="first_name" class="block text-sm font-bold text-gray-700 mb-1">Nombre</label>
                 <input id="first_name" name="first_name" type="text" required 
                     class="appearance-none relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm transition-colors" 
                     placeholder="Juan">
               </div>
               <div>
                 <label for="last_name" class="block text-sm font-bold text-gray-700 mb-1">Apellido</label>
                 <input id="last_name" name="last_name" type="text" required 
                     class="appearance-none relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm transition-colors" 
                     placeholder="Pérez">
               </div>
           </div>

           <div>
             <label for="email-address" class="block text-sm font-bold text-gray-700 mb-1">Correo Electrónico</label>
             <input id="email-address" name="email" type="email" autocomplete="email" required 
                 class="appearance-none relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm transition-colors" 
                 placeholder="tucorreo@ejemplo.com">
           </div>
           
           <div>
             <label for="password" class="block text-sm font-bold text-gray-700 mb-1">Contraseña</label>
             <input id="password" name="password" type="password" required 
                 class="appearance-none relative block w-full px-4 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm transition-colors" 
                 placeholder="••••••••">
           </div>
         </div>

         <!-- Error Alert -->
         <div id="register-error" class="hidden bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg">
            <div class="flex">
               <div class="flex-shrink-0">
                  <Icon name="tabler:alert-circle" class="h-5 w-5 text-red-500" />
               </div>
               <div class="ml-3">
                  <p class="text-sm text-red-700" id="register-error-msg">
                     Ocurrió un error al registrar tu cuenta.
                  </p>
               </div>
            </div>
         </div>

         <!-- Success Alert -->
         <div id="register-success" class="hidden bg-green-50 border-l-4 border-green-500 p-4 rounded-r-lg">
            <div class="flex">
               <div class="flex-shrink-0">
                  <Icon name="tabler:check" class="h-5 w-5 text-green-500" />
               </div>
               <div class="ml-3">
                  <p class="text-sm text-green-700 font-bold">
                     ¡Cuenta creada exitosamente! Redirigiendo...
                  </p>
               </div>
            </div>
         </div>

         <div>
           <button type="submit" id="submit-btn" class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-primary hover:bg-red-700 focus:outline-none focus:ring-4 focus:ring-primary/20 shadow-lg transition-all hover:shadow-xl">
             <span class="absolute left-0 inset-y-0 flex items-center pl-3">
               <Icon name="tabler:user-plus" class="h-5 w-5 text-white/50 group-hover:text-white/80 transition-colors" />
             </span>
             Registrarme
             <Icon name="tabler:loader-2" id="spinner" class="animate-spin h-5 w-5 ml-2 hidden" />
           </button>
         </div>
       </form>

       <div class="text-center mt-6 pt-6 border-t border-gray-100">
         <p class="text-sm text-gray-600">
           ¿Ya tienes cuenta? 
           <a href="/hogar/login" class="font-bold text-primary hover:text-red-700 transition-colors">Inicia sesión</a>
         </p>
       </div>
     </div>
  </div>
</ShopLayout>

<script>
  import { registerCustomer, loginCustomer, getMe } from '~/lib/auth';

  document.addEventListener('astro:page-load', async () => {
     try {
       const user = await getMe();
       if (user) {
         window.location.replace('/hogar/cuenta');
         return;
       }
     } catch { /* ignore */ }

     const form = document.getElementById('register-form') as HTMLFormElement;
     const errorBox = document.getElementById('register-error');
     const errorMsg = document.getElementById('register-error-msg');
     const successBox = document.getElementById('register-success');
     const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
     const spinner = document.getElementById('spinner');

     if (form) {
       form.addEventListener('submit', async (e) => {
         e.preventDefault();
         
         if(errorBox) errorBox.classList.add('hidden');
         
         const formData = new FormData(form);
         const first_name = formData.get('first_name') as string;
         const last_name = formData.get('last_name') as string;
         const email = formData.get('email') as string;
         const password = formData.get('password') as string;

         if(submitBtn) submitBtn.disabled = true;
         if(submitBtn) submitBtn.classList.add('opacity-75');
         if(spinner) spinner.classList.remove('hidden');

         try {
            // 1. Crear usuario
            await registerCustomer(first_name, last_name, email, password);
            
            // 2. Hacer login automático tras el registro
            await loginCustomer(email, password);

            if(successBox) successBox.classList.remove('hidden');

            setTimeout(() => {
                window.location.href = '/hogar/cuenta';
            }, 1000);

         } catch (err: unknown) {
            const error = err as Error;
            if(errorBox) errorBox.classList.remove('hidden');
            if(errorMsg) errorMsg.textContent = error.message || "No se pudo registrar la cuenta. Es posible que el correo ya exista.";
         } finally {
            if(submitBtn) submitBtn.disabled = false;
            if(submitBtn) submitBtn.classList.remove('opacity-75');
            if(spinner) spinner.classList.add('hidden');
         }
       });
     }
  });
</script>
