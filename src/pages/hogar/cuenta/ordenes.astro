---
import ShopLayout from '~/layouts/ShopLayout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = false;
---

<ShopLayout metadata={{ title: 'Mis Órdenes | Deiman' }}>
  <div class="min-h-[70vh] bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
     <div class="max-w-4xl mx-auto">
        
        <!-- Estado de Carga Inicial (Skeleton Loader) -->
        <div id="auth-loading" class="space-y-6 pt-12 pb-20">
            <!-- Skeleton Card 1 -->
            <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-gray-100 animate-pulse flex flex-col md:flex-row justify-between gap-6">
               <div class="flex flex-col justify-between w-full md:w-1/2 gap-6">
                  <div>
                    <div class="h-8 bg-gray-200 rounded-md w-40 mb-3"></div>
                    <div class="flex items-center gap-2 mb-2">
                       <div class="h-4 w-4 bg-gray-200 rounded-full"></div>
                       <div class="h-4 bg-gray-200 rounded-md w-28"></div>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                     <div class="h-8 w-8 bg-gray-200 rounded-full"></div>
                     <div class="h-8 w-8 bg-gray-200 rounded-full -ml-2"></div>
                     <div class="h-4 bg-gray-200 rounded-md w-16 ml-2"></div>
                  </div>
               </div>
               <div class="flex flex-col justify-between items-start md:items-end w-full md:w-1/3 gap-4 border-t md:border-t-0 pt-4 md:pt-0 border-gray-100">
                 <div class="text-left md:text-right w-full">
                    <div class="h-3 bg-gray-200 rounded-md w-20 mb-2 ml-0 md:ml-auto"></div>
                    <div class="h-8 bg-gray-200 rounded-md w-32 ml-0 md:ml-auto"></div>
                 </div>
                 <div class="flex gap-3">
                     <div class="h-8 w-24 bg-gray-200 rounded-xl"></div>
                     <div class="h-8 w-24 bg-gray-200 rounded-xl"></div>
                 </div>
               </div>
            </div>

            <!-- Skeleton Card 2 -->
            <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-gray-100 animate-pulse flex flex-col md:flex-row justify-between gap-6 opacity-60">
               <div class="flex flex-col justify-between w-full md:w-1/2 gap-6">
                  <div>
                    <div class="h-8 bg-gray-200 rounded-md w-36 mb-3"></div>
                    <div class="flex items-center gap-2 mb-2">
                       <div class="h-4 w-4 bg-gray-200 rounded-full"></div>
                       <div class="h-4 bg-gray-200 rounded-md w-24"></div>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                     <div class="h-8 w-8 bg-gray-200 rounded-full"></div>
                     <div class="h-4 bg-gray-200 rounded-md w-16 ml-2"></div>
                  </div>
               </div>
               <div class="flex flex-col justify-between items-start md:items-end w-full md:w-1/3 gap-4 border-t md:border-t-0 pt-4 md:pt-0 border-gray-100">
                 <div class="text-left md:text-right w-full">
                    <div class="h-3 bg-gray-200 rounded-md w-20 mb-2 ml-0 md:ml-auto"></div>
                    <div class="h-8 bg-gray-200 rounded-md w-28 ml-0 md:ml-auto"></div>
                 </div>
                 <div class="flex gap-3">
                     <div class="h-8 w-24 bg-gray-200 rounded-xl"></div>
                     <div class="h-8 w-20 bg-gray-200 rounded-xl"></div>
                 </div>
               </div>
            </div>
        </div>

        <!-- Contenido Protegido (Oculto hasta validar JWT) -->
        <div id="protected-content" class="hidden opacity-0 transition-opacity duration-500">
            
            <!-- Encabezado de la cuenta -->
            <div class="mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
               <div>
                  <a href="/hogar/cuenta" class="inline-flex items-center text-sm font-bold text-gray-500 hover:text-primary transition-colors mb-2">
                     <Icon name="tabler:arrow-left" class="w-4 h-4 mr-1" />
                     Volver a mi Perfil
                  </a>
                  <h1 class="text-3xl font-black text-gray-900">Historial de Compras</h1>
               </div>
            </div>

            <!-- Contenedor Lista de Órdenes -->
            <div id="orders-container" class="space-y-6">
                <!-- Vacio -> JS inyectará el contenido aquí -->
            </div>

        </div>

     </div>
  </div>
</ShopLayout>

<!-- Template Invisible para las Cards de Orden -->
<template id="order-card-template">
    <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-gray-100 flex flex-col gap-6 hover:shadow-md transition-all">
       <div class="flex flex-col md:flex-row justify-between gap-6">
           <div class="flex flex-col justify-between">
              <div>
                <div class="flex items-center gap-3 mb-2">
                   <h3 class="text-xl font-black text-gray-900 font-mono tracking-tighter order-num">#ORDER</h3>
                   <span class="px-3 py-1 bg-green-100 text-green-700 text-[10px] font-bold uppercase rounded-full order-status border border-green-200"></span>
                </div>
                <p class="text-sm text-gray-500 flex items-center gap-1.5 mb-6">
                   <Icon name="tabler:calendar" class="w-4 h-4" />
                   <span class="order-date">Date</span>
                </p>
              </div>
              <div class="flex items-center gap-2">
                 <div class="flex -space-x-2 overflow-hidden order-images">
                 </div>
                 <span class="text-xs font-bold text-gray-400 ml-2 order-items-count">X Items</span>
              </div>
           </div>

           <div class="flex flex-col justify-between items-start md:items-end border-t md:border-t-0 pt-4 md:pt-0 border-gray-100">
             <div class="text-left md:text-right mb-4">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Monto Total</p>
                <p class="text-2xl font-black text-primary order-total">$0.00</p>
             </div>
             <div class="flex items-center gap-3">
                 <button class="order-toggle-btn inline-flex items-center justify-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 text-xs font-bold rounded-xl hover:bg-gray-50 transition-colors">
                    Ver Artículos
                    <Icon name="tabler:chevron-down" class="w-4 h-4 transition-transform duration-300 ToggleIconTag" />
                 </button>
                 <a href="#" class="order-link inline-flex items-center justify-center gap-2 px-5 py-2 text-white bg-primary text-xs font-bold rounded-xl hover:bg-red-700 transition-colors shadow-md shadow-primary/20">
                    Recibo
                 </a>
             </div>
           </div>
       </div>

       <!-- Accordion Detalles de los articulos (Oculto por defecto) -->
       <div class="order-details-accordion hidden border-t border-gray-100 pt-6 mt-2">
          <h4 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Productos en esta orden</h4>
          <ul class="space-y-4 order-products-list">
             <!-- Se inyectaran <li> aqui -->
          </ul>
       </div>
    </div>
</template>

<!-- Template para "No hay ordenes" -->
<template id="empty-state-template">
   <div class="bg-white rounded-3xl p-12 text-center border-2 border-dashed border-gray-200">
      <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
         <Icon name="tabler:receipt-off" class="w-10 h-10 text-gray-400" />
      </div>
      <h3 class="text-xl font-black text-gray-900 mb-2">Aún no tienes compras</h3>
      <p class="text-gray-500 mb-8 max-w-sm mx-auto">Cuando realices tu primer pedido, este aparecerá aquí junto con su recibo correspondiente.</p>
      <a href="/hogar" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white text-sm font-bold rounded-xl hover:bg-red-700 transition-colors shadow-lg shadow-primary/20">
         Ir a la Tienda
      </a>
   </div>
</template>

<script>
  import { getMe } from '~/lib/auth';
  import { medusaClient } from '~/lib/medusa';

  document.addEventListener('astro:page-load', async () => {
      const loadingState = document.getElementById('auth-loading');
      const protectedContent = document.getElementById('protected-content');
      const container = document.getElementById('orders-container');
      
      if (!loadingState || !container) return;

      try {
         // Validar Sesión
         const customer = await getMe();
         if (!customer) {
            window.location.replace('/hogar/login');
            return;
         }

         // Headers de Autenticación
         let headers: Record<string, string> = {};
         const token = localStorage.getItem("medusa_auth_token");
         if (token) {
             headers = { Authorization: `Bearer ${token}` };
         }

         // Heads up: en JS SDK v2: medusaClient.store.order.list(query, config)
         const { orders } = await medusaClient.store.order.list(
             { fields: '*items,*items.variant' },
             // @ts-expect-error - The SDK type definition for headers throws error expecting string|null
             { headers }
         );

         // Formatear Moneda
         const formatter = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' });
         
         if (!orders || orders.length === 0) {
             const emptyTemplate = document.getElementById('empty-state-template') as HTMLTemplateElement;
             container.appendChild(emptyTemplate.content.cloneNode(true));
         } else {
             const cardTemplate = document.getElementById('order-card-template') as HTMLTemplateElement;
             
             orders.forEach(order => {
                const clone = cardTemplate.content.cloneNode(true) as DocumentFragment;
                
                // Setear Data
                const displayId = order.display_id || order.id.split('_')[1].slice(-6).toUpperCase();
                clone.querySelector('.order-num')!.textContent = `#${displayId}`;
                clone.querySelector('.order-status')!.textContent = order.status === 'completed' ? 'Completado' : order.status || 'Pendiente';
                clone.querySelector('.order-date')!.textContent = new Date(order.created_at).toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' });
                clone.querySelector('.order-total')!.textContent = formatter.format(order.total || 0);
                
                const link = clone.querySelector('.order-link') as HTMLAnchorElement;
                link.href = `/hogar/order/${order.id}`;

                // Miniaturas y Renderizado de Lista
                const itemsCountLabel = clone.querySelector('.order-items-count')!;
                const imagesContainer = clone.querySelector('.order-images')!;
                const productsList = clone.querySelector('.order-products-list')!;
                let totalItemsCount = 0;

                if (order.items && order.items.length > 0) {
                   
                   // Loop para UI del desplegable interior y sumatoria de totales
                   order.items.forEach((item: Record<string, unknown>) => {
                       totalItemsCount += (item.quantity as number) || 1;
                       
                       const li = document.createElement('li');
                       li.className = "flex items-center gap-4 bg-gray-50 p-3 rounded-xl border border-gray-100";
                       
                       const imgDetails = document.createElement('img');
                       imgDetails.src = (item.thumbnail as string) || 'https://via.placeholder.com/150';
                       imgDetails.className = "w-12 h-12 object-cover rounded-md bg-white border border-gray-200";
                       
                       const divInfo = document.createElement('div');
                       divInfo.className = "flex-1 overflow-hidden";
                       const title = document.createElement('p');
                       title.className = "text-sm font-bold text-gray-900 truncate";
                       title.textContent = item.title as string;
                       
                       const variantData = item.variant as Record<string, unknown> | undefined;
                       const variantInfo = document.createElement('p');
                       variantInfo.className = "text-xs text-gray-500 truncate mt-0.5";
                       variantInfo.textContent = `Variante: ${variantData?.title || 'Única'} | Cantidad: ${item.quantity}`;
                       
                       divInfo.appendChild(title);
                       divInfo.appendChild(variantInfo);
                       
                       const priceBlock = document.createElement('div');
                       priceBlock.className = "text-right font-medium text-sm text-gray-900 whitespace-nowrap pl-2 block";
                       priceBlock.textContent = formatter.format(((item.unit_price as number) * (item.quantity as number)) || 0);
                       
                       li.appendChild(imgDetails);
                       li.appendChild(divInfo);
                       li.appendChild(priceBlock);
                       
                       productsList.appendChild(li);
                   });

                   // Loop para Miniaturas colapsadas (top elements)
                   order.items.slice(0, 4).forEach((item: Record<string, unknown>) => {
                       if (item.thumbnail) {
                           const img = document.createElement('img');
                           img.src = item.thumbnail as string;
                           img.className = "inline-block h-8 w-8 rounded-full ring-2 ring-white object-cover bg-gray-100 z-0 relative";
                           imagesContainer.appendChild(img);
                       }
                   });
                   
                   // Si hay mas de 4 (badges)
                   if (order.items.length > 4) {
                       const more = document.createElement('div');
                       more.className = "inline-flex h-8 w-8 items-center justify-center rounded-full bg-gray-100 ring-2 ring-white text-[9px] font-bold text-gray-500 z-10 relative";
                       more.textContent = `+${order.items.length - 4}`;
                       imagesContainer.appendChild(more);
                   }
                }
                
                itemsCountLabel.textContent = `${totalItemsCount} ${totalItemsCount === 1 ? 'Artículo' : 'Artículos'}`;

                // Logica del Boton Desplegable
                const toggleBtn = clone.querySelector('.order-toggle-btn') as HTMLButtonElement | null;
                const accordion = clone.querySelector('.order-details-accordion') as HTMLDivElement | null;
                const toggleIcon = clone.querySelector('.ToggleIconTag') as HTMLElement | null;
                
                if (toggleBtn && accordion) {
                   toggleBtn.addEventListener('click', () => {
                       accordion.classList.toggle('hidden');
                       if (toggleIcon) toggleIcon.classList.toggle('rotate-180');
                   });
                }

                container.appendChild(clone);
             });
         }

         // Show Content
         loadingState.classList.add('hidden');
         if (protectedContent) {
            protectedContent.classList.remove('hidden');
            void protectedContent.offsetWidth;
            protectedContent.classList.remove('opacity-0');
         }

      } catch (err: unknown) {
         console.error("Error validando sesión / Listando compras:", err);
         const errorBox = document.createElement('div');
         errorBox.className = "p-4 bg-red-50 text-red-600 rounded-xl mt-4 max-w-lg mx-auto text-center border border-red-200 text-sm";
         errorBox.innerText = `Ocurrió un error al cargar las órdenes: ${(err as Error).message || JSON.stringify(err)}`;
         
         loadingState.classList.add('hidden');
         container?.appendChild(errorBox);
         protectedContent?.classList.remove('hidden', 'opacity-0');
      }
  });
</script>
