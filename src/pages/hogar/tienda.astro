---
import ShopLayout from '~/layouts/ShopLayout.astro';
import ProductGrid from '~/components/hogar/ProductGrid.astro';
import ShopSidebar from '~/components/hogar/ShopSidebar.astro';
import ShopTopBar from '~/components/hogar/ShopTopBar.astro';
import { Icon } from 'astro-icon/components';
import { medusaClient } from '~/lib/medusa';
import logoRed from '~/assets/logo/deiman-new-red.svg';

const metadata = {
  title: 'Tienda Hogar | Deiman',
  description: 'Explora todos los productos de Deiman para tu cocina casera. Sabores, colores y sazonadores.',
};

interface MedusaProduct {
  id: string;
  title: string;
  handle: string;
  description?: string;
  thumbnail?: string | null;
  variants?: Array<{
    title: string;
    calculated_price?: number;
  }>;
}

interface MedusaCategory {
  id: string;
  name: string;
  handle: string;
  [key: string]: unknown;
}

interface MedusaCollection {
  id: string;
  title: string;
  handle: string;
  [key: string]: unknown;
}

// Fetch products and categories from MedusaJS API
let medusaProducts: MedusaProduct[] = [];
let categories: MedusaCategory[] = [];
let collections: MedusaCollection[] = [];
let fetchError: string | null = null;
try {
  const { products } = await medusaClient.store.product.list({
    limit: 50,
    fields: '*variants,*categories'
  });
  medusaProducts = products;

  const { product_categories } = await medusaClient.store.category.list({ limit: 50 });
  categories = product_categories;

  const { collections: fetchedCollections } = await medusaClient.store.collection.list({ limit: 50 });
  collections = fetchedCollections;
} catch (error) {
  console.error("Error conectando a MedusaJS:", error);
  fetchError = "No se pudo conectar a la tienda en vivo.";
}
---

<ShopLayout metadata={metadata}>
  <!-- Contenido de tienda -->
  <div class="relative z-10 w-full">
    <!-- Hero Promo Banner Carousel -->
    <section class="relative overflow-hidden h-[350px] md:h-[450px] lg:h-[500px] mb-8 lg:mb-12 w-full group" id="shop-hero-carousel">
    
    <!-- Slides Container -->
    <div class="flex h-full transition-transform duration-700 ease-in-out w-full" id="carousel-slides">
      
      <!-- Slide 1: New York Cookies -->
      <div class="w-full flex-shrink-0 relative h-full">
        <!-- New York Cookies Background - Mantenemos el encuadre ajustado a la izquierda para ver las botellas de la derecha -->
        <img 
          src="/images/banners/newyork-cookies-banner.jpg" 
          alt="Deiman Escencias para recetas de cookies newyork" 
          class="absolute inset-0 w-full h-full object-cover object-[20%_center] lg:object-[25%_center]"
        />
        
        <!-- Degradado base para asegurar legibilidad en ambos extremos -->
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/50 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute inset-y-0 right-0 w-1/3 bg-gradient-to-l from-black/40 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute inset-y-0 left-0 w-1/3 bg-gradient-to-r from-black/40 to-transparent z-10 pointer-events-none"></div>

        <!-- 1. BLOQUE IZQUIERDO: Branding y Título Principal -->
        <div class="absolute top-6 left-4 md:top-12 md:left-12 lg:top-16 lg:left-20 z-20 flex flex-col items-start intersect-once intersect-quarter opacity-0 -translate-x-8 intersect:opacity-100 intersect:translate-x-0 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] delay-100">
          
          <!-- Logo Deiman y Badge de Presentación -->
          <div class="flex items-center gap-2 md:gap-3 mb-2">
            <img src={logoRed.src} alt="Deiman Escencias" class="h-5 md:h-8 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]" />
            <div class="hidden md:block h-4 w-[1px] bg-white/40"></div>
            <span class="hidden md:block text-white/90 text-[10px] md:text-xs uppercase tracking-[0.3em] font-bold drop-shadow-md">Presenta</span>
          </div>
          
          <!-- Bloque Tipográfico Superpuesto Estilo Poster (Cookies) -->
          <div class="relative flex flex-col items-center mt-1">
            <h2 class="font-['Oi'] text-2xl md:text-4xl lg:text-5xl text-[#facc15] leading-[0.7] z-20 drop-shadow-lg transition-transform hover:scale-[1.02] duration-500" style="text-shadow: 1px 1px 0 #b45309, 2px 2px 0px rgba(0,0,0,0.5);">
              NEW YORK
            </h2>
            <h2 class="font-['Oi'] text-3xl md:text-5xl lg:text-6xl text-white leading-[0.7] z-10 -mt-1 md:-mt-4 drop-shadow-xl transition-transform hover:scale-[1.02] duration-500 origin-center" style="text-shadow: 1px 1px 0 #1e3a8a, 2px 2px 0px rgba(0,0,0,0.5);">
              COOKIES
            </h2>
            <!-- Firma manuscrita superpuesta central -->
            <p class="hidden md:block font-['Dancing_Script'] text-2xl md:text-3xl text-amber-200 absolute -bottom-6 left-1/2 -translate-x-1/2 z-30 drop-shadow-md rotate-[-2deg] whitespace-nowrap">
              el secreto está en la esencia
            </p>
          </div>
        </div>

        <!-- 2. BLOQUE DERECHO: Contenido Descriptivo y CTA -->
        <div class="absolute bottom-10 right-4 md:bottom-16 md:right-12 lg:bottom-20 lg:right-20 z-20 flex flex-col items-end text-right max-w-[200px] md:max-w-md intersect-once intersect-quarter opacity-0 translate-x-8 intersect:opacity-100 intersect:translate-x-0 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] delay-300">
          
          <!-- Título Secundario / Gancho (Dancing Script) -->
          <h3 class="font-['Dancing_Script'] text-2xl md:text-4xl lg:text-5xl text-white mb-3 md:mb-2 drop-shadow-lg leading-none">
            Hornea la perfección en <span class="text-amber-300">cada bocado</span>.
          </h3>
          
          <!-- Descripción Técnica Fluida -->
          <p class="hidden md:block text-[12px] md:text-sm text-gray-100/90 font-medium drop-shadow-md leading-relaxed mb-6 mt-2">
            Eleva tus recetas combinando la intensidad pura de nuestra Vainilla, la suavidad aterciopelada de la Manteca y ese inconfundible toque Cookie. El trío definitivo para lograr el auténtico sabor de la gran manzana en tu propia cocina.
          </p>
          
          <!-- Botón CTA Sutil e Integrado (con animación bounce individual) -->
          <a 
            href="/hogar/tienda" 
            class="group relative inline-flex items-center justify-center overflow-hidden rounded-full border border-white/40 bg-white/10 px-4 py-2 md:px-6 md:py-2.5 text-[11px] md:text-sm font-semibold text-white backdrop-blur-md transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:bg-white hover:text-gray-900 hover:border-white hover:shadow-[0_0_20px_rgba(255,255,255,0.3)] intersect-once opacity-0 scale-90 intersect:opacity-100 intersect:scale-100 delay-500"
          >
            <span class="mr-1.5 md:mr-2 relative z-10">Conseguir Esencias</span>
            <Icon name="tabler:arrow-up-right" class="w-3.5 h-3.5 md:w-4 md:h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
        </div>

      </div>

      <!-- Slide 2 -->
      <div class="w-full flex-shrink-0 relative h-full">
        <div class="absolute inset-0 bg-secondary/20 mix-blend-multiply z-10"></div>
        <img 
          src="https://images.unsplash.com/photo-1505935428862-770b6f24f629?auto=format&fit=crop&q=80&w=2000" 
          alt="Cocina casera 2" 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 via-gray-900/40 to-transparent z-10"></div>
        <div class="relative z-20 h-full flex flex-col items-center md:items-start justify-center text-center md:text-left px-12 md:px-24 w-full text-white">
          <span class="px-3 py-1 text-xs md:text-sm font-bold tracking-widest uppercase bg-primary text-white rounded-md mb-4 shadow-lg intersect-once intersect-quarter opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 delay-100">
            Sabores Únicos
          </span>
          <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-3 md:mb-4 drop-shadow-md intersect-once intersect-quarter opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 delay-200">
            Esencias Deiman
          </h2>
          <p class="text-xs md:text-lg max-w-[260px] md:max-w-xl text-white/90 drop-shadow-sm intersect-once intersect-quarter opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 delay-300">
            Concentración superior para realzar cada una de tus recetas sin alterar la estructura original.
          </p>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="w-full flex-shrink-0 relative h-full">
        <div class="absolute inset-0 bg-gray-900/40 mix-blend-multiply z-10"></div>
        <img 
          src="https://images.unsplash.com/photo-1512149177596-f817c7ef5d4c?auto=format&fit=crop&q=80&w=2000" 
          alt="Cocina casera 3" 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-transparent to-transparent z-10"></div>
        <div class="relative z-20 h-full flex flex-col items-center justify-end pb-12 md:pb-16 text-center px-6 w-full text-white">
          <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-2 md:mb-2 drop-shadow-md intersect-once intersect-quarter opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 delay-100">
            Colores vibrantes
          </h2>
          <p class="text-xs md:text-lg max-w-[260px] md:max-w-2xl text-white/90 drop-shadow-sm intersect-once intersect-quarter opacity-0 translate-y-4 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 delay-200">
            Logra los tonos que imaginas con nuestros colorantes hidrosolubles y liposolubles.
          </p>
        </div>
      </div>

    </div>

    <!-- Navigation Dots -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30 flex gap-2">
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/40 hover:bg-white transition-all duration-300 aria-selected:bg-white aria-selected:w-6" aria-label="Ir a diapositiva 1" aria-selected="true" data-index="0"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/40 hover:bg-white transition-all duration-300 aria-selected:bg-white aria-selected:w-6" aria-label="Ir a diapositiva 2" aria-selected="false" data-index="1"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/40 hover:bg-white transition-all duration-300 aria-selected:bg-white aria-selected:w-6" aria-label="Ir a diapositiva 3" aria-selected="false" data-index="2"></button>
    </div>

    <!-- Arrow Controls (Visible on Desktop Hover) -->
    <button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-30 bg-black/30 hover:bg-primary/90 text-white p-2 rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-110" aria-label="Anterior">
      <Icon name="tabler:chevron-left" class="w-6 h-6" />
    </button>
    <button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-30 bg-black/30 hover:bg-primary/90 text-white p-2 rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-110" aria-label="Siguiente">
      <Icon name="tabler:chevron-right" class="w-6 h-6" />
    </button>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const carousel = document.getElementById("shop-hero-carousel");
      if (!carousel) return;

      const slidesContainer = document.getElementById("carousel-slides");
      const slides = slidesContainer?.children;
      const dots = carousel.querySelectorAll(".carousel-dot");
      const prevBtn = document.getElementById("carousel-prev");
      const nextBtn = document.getElementById("carousel-next");
      
      if (!slidesContainer || !slides || slides.length === 0) return;

      let currentIndex = 0;
      const totalSlides = slides.length;
      let autoplayInterval: NodeJS.Timeout;
      let isHovered = false;

      const updateCarousel = (index: number) => {
        currentIndex = index;
        // Mover contenedor
        slidesContainer.style.transform = `translateX(-${currentIndex * 100}%)`;
        // Actualizar dots
        dots.forEach((dot, i) => {
          dot.setAttribute("aria-selected", i === currentIndex ? "true" : "false");
        });
      };

      const nextSlide = () => {
        updateCarousel((currentIndex + 1) % totalSlides);
      };

      const prevSlide = () => {
        updateCarousel((currentIndex - 1 + totalSlides) % totalSlides);
      };

      const startAutoplay = () => {
        clearInterval(autoplayInterval); // Siempre limpiar antes de crear uno nuevo
        if (!isHovered) {
          autoplayInterval = setInterval(nextSlide, 5000);
        }
      };

      const resetAutoplay = () => {
        startAutoplay();
      };

      // Events
      nextBtn?.addEventListener("click", () => { nextSlide(); resetAutoplay(); });
      prevBtn?.addEventListener("click", () => { prevSlide(); resetAutoplay(); });

      dots.forEach((dot) => {
        dot.addEventListener("click", (e) => {
          const index = parseInt((e.target as HTMLElement).getAttribute("data-index") || "0", 10);
          updateCarousel(index);
          resetAutoplay();
        });
      });

      // Pause sequence on hover to allow reading
      carousel.addEventListener("mouseenter", () => {
        isHovered = true;
        clearInterval(autoplayInterval);
      });
      carousel.addEventListener("mouseleave", () => {
        isHovered = false;
        startAutoplay();
      });

      // Swipe support (opcional para mobile)
      let touchStartX = 0;
      let touchEndX = 0;
      carousel.addEventListener("touchstart", (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, {passive: true});
      carousel.addEventListener("touchend", (e) => {
        touchEndX = e.changedTouches[0].screenX;
        if (touchStartX - touchEndX > 50) { nextSlide(); resetAutoplay(); }
        if (touchEndX - touchStartX > 50) { prevSlide(); resetAutoplay(); }
      }, {passive: true});

      // Initialize
      startAutoplay();
    });
  </script>

  <!-- Shop Main 2-Col Layout -->
  <div class="mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-8 pb-24">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      
      <!-- Sidebar / Filters -->
      <ShopSidebar categories={categories} collections={collections} />

      <!-- Products Grid Area -->
      <div class="w-full lg:w-3/4">
        <!-- Top Action Bar Modular -->
        <ShopTopBar resultsCount={medusaProducts.length} />

        <!-- Grid Modular -->
        <ProductGrid 
          products={medusaProducts} 
          fetchError={fetchError} 
        />
      </div>
      </div>
    </div>
  </div>
</ShopLayout>

