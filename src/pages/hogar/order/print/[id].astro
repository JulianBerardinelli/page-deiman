---
export const prerender = false;

import { medusaClient } from '~/lib/medusa';
import deimanLogoNewRed from '~/assets/logo/deiman-new-red.svg';

const { id } = Astro.params;

let order;
let error;

try {
  const result = await medusaClient.store.order.retrieve(id as string, {
    fields: '*items,*items.variant,*shipping_address,*billing_address'
  });
  order = result.order;
} catch (err) {
  console.error("Error fetching order for print:", err);
  error = err;
}

type OrderItem = Record<string, unknown>;

const formatter = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' });

// Simple date formatter
const formatDate = (dateString: string) => {
   if (!dateString) return '-';
   return new Date(dateString).toLocaleDateString('es-AR', {
      year: 'numeric', month: 'long', day: 'numeric',
      hour: '2-digit', minute:'2-digit'
   });
}
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Recibo - {order ? order.display_id || order.id.split('_')[1].slice(-6).toUpperCase() : 'Error'}</title>
    
    <!-- Incluir Tipografías para la impresión si lo deseamos -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    
    <style>
        /* Estilos básicos sin depender de Tailwind (aunque Astro compilaría las clases de Tailwind de todas formas, preferimos garantizar que la impresión salga perfecta) */
        @tailwind base;
        @tailwind components;
        @tailwind utilities;
        
        body {
            font-family: 'Inter', sans-serif;
            color: #000;
            background: #fff;
            margin: 0;
            padding: 0;
        }

        .print-container {
            max-w: 800px;
            margin: 0 auto;
            padding: 40px;
        }

        @media print {
            @page {
                size: A4 portrait;
                margin: 1.5cm;
            }
            body { 
                background: white; 
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            .no-print {
                display: none !important;
            }
            .print-container {
                padding: 0;
                max-width: 100%;
            }
            .page-break-inside-avoid {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>

    {error || !order ? (
        <div class="print-container">
            <h1 class="text-2xl font-bold text-red-600">No se pudo generar el recibo</h1>
            <p>El pedido no existe o no tiene permisos para verlo.</p>
        </div>
    ) : (
        <div class="print-container">

            <!-- Cabecera del Recibo -->
            <div class="flex justify-between items-end border-b-2 border-gray-900 pb-8 mb-8">
                <div>
                    <img class="w-40" src={deimanLogoNewRed.src} alt="Logo Deiman Argentina" />
                </div>
                <div class="text-right">
                    <h2 class="text-xl font-bold uppercase tracking-widest text-gray-400">RECIBO DE COMPRA</h2>
                    <p class="font-mono text-2xl font-black mt-1">#{order.display_id || order.id.split('_')[1].slice(-6).toUpperCase()}</p>
                    <p class="text-sm text-gray-500 mt-2">{formatDate(order.created_at)}</p>
                </div>
            </div>

            <!-- Datos del Cliente / Envío -->
            <div class="grid grid-cols-2 gap-12 mb-10">
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2 border-b border-gray-200 pb-1">Facturado a</h3>
                    <p class="font-bold">{order.billing_address?.first_name || order.shipping_address?.first_name} {order.billing_address?.last_name || order.shipping_address?.last_name}</p>
                    <p class="text-sm">{order.email}</p>
                    {order.shipping_address?.phone && <p class="text-sm">Tel: {order.shipping_address.phone}</p>}
                </div>
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2 border-b border-gray-200 pb-1">Enviar a</h3>
                    {order.shipping_address ? (
                        <>
                            <p class="font-bold">{order.shipping_address.first_name} {order.shipping_address.last_name}</p>
                            <p class="text-sm">{order.shipping_address.address_1} {order.shipping_address.address_2 || ''}</p>
                            <p class="text-sm">{order.shipping_address.city}, {order.shipping_address.province} {order.shipping_address.postal_code}</p>
                        </>
                    ) : (
                        <p class="text-sm italic">Sin dirección de envío física registrada.</p>
                    )}
                </div>
            </div>

            <!-- Tabla de Artículos -->
            <div class="mb-10 page-break-inside-avoid">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b-2 border-gray-900">
                            <th class="py-3 text-xs font-bold uppercase tracking-widest text-gray-400 w-3/5">Artículo</th>
                            <th class="py-3 text-xs font-bold uppercase tracking-widest text-gray-400 text-center w-1/5">Cant.</th>
                            <th class="py-3 text-xs font-bold uppercase tracking-widest text-gray-400 text-right w-1/5">Total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {order.items && order.items.map((item: OrderItem) => {
                            const variant = item.variant as OrderItem | undefined;
                            return (
                            <tr class="page-break-inside-avoid">
                                <td class="py-4">
                                    <p class="font-bold text-gray-900">{item.title as string}</p>
                                    <p class="text-xs text-gray-500 mt-0.5">Ref/Variante: {variant?.title || 'Única'} (SKU: {variant?.sku || '-'})</p>
                                </td>
                                <td class="py-4 text-center font-medium">{item.quantity as number}</td>
                                <td class="py-4 text-right font-bold">{formatter.format(((item.unit_price as number) * (item.quantity as number)) || 0)}</td>
                            </tr>
                            );
                        })}
                    </tbody>
                </table>
            </div>

            <!-- Resumen Financiero -->
            <div class="flex justify-end page-break-inside-avoid">
                <div class="w-1/2">
                    <div class="flex justify-between py-2 border-b border-gray-100">
                        <span class="text-sm text-gray-500">Subtotal de la orden</span>
                        <span class="font-medium">{formatter.format(order.item_total || 0)}</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-gray-100">
                        <span class="text-sm text-gray-500">Costo de Envío</span>
                        <span class="font-medium">{formatter.format(order.shipping_total || 0)}</span>
                    </div>
                    {order.tax_total > 0 && (
                        <div class="flex justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-500">Impuestos (IVA)</span>
                            <span class="font-medium">{formatter.format(order.tax_total)}</span>
                        </div>
                    )}
                    <div class="flex justify-between py-4 border-b-2 border-gray-900 mt-2">
                        <span class="text-base font-bold uppercase tracking-widest">Total Pagado</span>
                        <span class="text-xl font-black">{formatter.format(order.total || 0)}</span>
                    </div>
                </div>
            </div>

            <!-- Footer / Notas legales -->
            <div class="mt-16 pt-8 border-t border-gray-200 text-center text-xs text-gray-400 page-break-inside-avoid">
                <p class="mb-2">Este documento es un comprobante electrónico de compra y no reemplaza a la factura legal si aplican impuestos gravados locales de mayor jerarquía.</p>
                <p>ID Transacción Interna: {order.id}</p>
                <div class="mt-6 no-print">
                    <button onclick="window.print()" class="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:bg-primary/90">Imprimir Ahora</button>
                    <p class="mt-2 text-[10px] italic">Consejo: Puedes guardarlo como PDF desde la ventana de impresión.</p>
                </div>
            </div>

        </div>
    )}

    <script is:inline>
        // Disparar diálogo de impresión automáticamente (ideal para que la UX de "Descargar PDF" sea 1 click)
        window.onload = function() {
            setTimeout(() => {
                window.print();
            }, 500);
        };
    </script>
</body>
</html>
