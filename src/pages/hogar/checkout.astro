---
import ShopLayout from '~/layouts/ShopLayout.astro';
import Logo from '~/components/Logo.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Seguridad y Pago - Deiman',
};
---

<ShopLayout metadata={metadata}>
  <!-- Header de Checkout simplificado para que no haya fugas de navegación -->
  <header slot="header" class="border-b border-gray-100 bg-white sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <a href="/hogar" class="inline-block transition-transform duration-200 hover:scale-105">
        <Logo />
      </a>
      <a href="/hogar" class="text-sm font-semibold text-gray-500 hover:text-primary flex items-center gap-1 group">
        <Icon name="tabler:shopping-cart" class="w-4 h-4" />
        <span class="relative">
          Volver a tienda
          <span class="absolute bottom-0 left-0 h-[2px] bg-primary transition-all duration-300 ease-in-out w-0 group-hover:w-full"></span>
        </span>
      </a>
    </div>
  </header>

  <!-- Checkout Principal (2 Columnas) -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-16">
    <div class="lg:grid lg:grid-cols-12 lg:gap-x-12 xl:gap-x-20">
      
      <!-- Lado Izquierdo: Formularios Pasos (Multi-step) -->
      <section class="lg:col-span-7 2xl:col-span-8 flex flex-col gap-6" id="checkout-steps-container">
        <div class="mb-4">
          <h1 class="text-2xl font-black text-gray-900 md:text-3xl">Finalizar Compra</h1>
          <p class="text-gray-500 mt-2 text-sm">Por favor completa tus datos para generar la orden.</p>
        </div>

        <!-- PASO 1: Email -->
        <article id="step-1-email" class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm relative overflow-hidden transition-all duration-500">
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-primary text-white text-xs font-bold leading-none">1</span>
            <h2 class="text-lg font-bold text-gray-900">Datos de Contacto</h2>
          </div>
          
          <form id="form-email" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Correo Electrónico</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="tu@email.com"
                class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border"
              />
            </div>
            
            <button 
              type="submit" 
              class="w-full sm:w-auto mt-2 relative group inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-bold text-white transition-all duration-300 hover:bg-primary/95 focus:outline-none focus:ring-4 focus:ring-primary/20 shadow-lg shadow-primary/20 hover:shadow-primary/40"
            >
              Continuar
              <Icon name="tabler:arrow-right" class="w-4 h-4" />
            </button>
          </form>

          <!-- Capa de bloqueo durante la carga -->
          <div id="step-1-loading-overlay" class="absolute inset-0 bg-white/60 backdrop-blur-sm z-20 hidden items-center justify-center rounded-2xl">
            <span class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></span>
          </div>

          <!-- Accordion Summary (Completed State) -->
          <div id="step-1-complete-summary" class="hidden items-center justify-between bg-gray-50 p-4 rounded-xl border border-gray-100">
            <div class="flex flex-col">
               <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-0.5">Contacto</span>
               <span id="summary-email" class="text-sm font-bold text-gray-900">-</span>
            </div>
            <button type="button" class="text-primary text-sm font-bold hover:underline" onclick="window.setActiveStep(1)">
              Editar
            </button>
          </div>
        </article>

          <!-- PASO 2: Shipping -->
        <article id="step-2-shipping" class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm opacity-50 pointer-events-none transition-all duration-500 relative overflow-hidden">
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-xs font-bold leading-none transition-colors" id="step-2-badge">2</span>
            <h2 class="text-lg font-bold text-gray-900">Dirección de Envío</h2>
          </div>
          
          <form id="form-shipping" class="space-y-4">
            <!-- Selector de Direcciones Guardadas -->
            <div id="saved-addresses-container" class="space-y-3 mb-4 hidden"></div>

            <div id="new-address-form-fields" class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                  <input type="text" id="first_name" name="first_name" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                </div>
                <div>
                  <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1">Apellido</label>
                  <input type="text" id="last_name" name="last_name" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                 <div class="sm:col-span-2">
                   <label for="address_1" class="block text-sm font-medium text-gray-700 mb-1">Dirección Exacta (Calle y Altura)</label>
                   <input type="text" id="address_1" name="address_1" required placeholder="Ej: Av. Córdoba 1234" class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                 </div>
                 <div>
                   <label for="address_2" class="block text-sm font-medium text-gray-700 mb-1">Piso / Dpto</label>
                   <input type="text" id="address_2" name="address_2" placeholder="Ej: 4A" class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                 </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                 <div class="lg:col-span-1">
                   <label for="city" class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
                   <input type="text" id="city" name="city" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                 </div>
                 <div class="lg:col-span-1">
                   <label for="province" class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
                   <select id="province" name="province" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border">
                      <option value="" disabled selected>Seleccionar...</option>
                      <option value="Buenos Aires">Buenos Aires</option>
                      <option value="CABA">Ciudad Autónoma de Buenos Aires</option>
                      <option value="Catamarca">Catamarca</option>
                      <option value="Chaco">Chaco</option>
                      <option value="Chubut">Chubut</option>
                      <option value="Cordoba">Córdoba</option>
                      <option value="Corrientes">Corrientes</option>
                      <option value="Entre Rios">Entre Ríos</option>
                      <option value="Formosa">Formosa</option>
                      <option value="Jujuy">Jujuy</option>
                      <option value="La Pampa">La Pampa</option>
                      <option value="La Rioja">La Rioja</option>
                      <option value="Mendoza">Mendoza</option>
                      <option value="Misiones">Misiones</option>
                      <option value="Neuquen">Neuquén</option>
                      <option value="Rio Negro">Río Negro</option>
                      <option value="Salta">Salta</option>
                      <option value="San Juan">San Juan</option>
                      <option value="San Luis">San Luis</option>
                      <option value="Santa Cruz">Santa Cruz</option>
                      <option value="Santa Fe">Santa Fe</option>
                      <option value="Santiago del Estero">Santiago del Estero</option>
                      <option value="Tierra del Fuego">Tierra del Fuego</option>
                      <option value="Tucuman">Tucumán</option>
                   </select>
                 </div>
                 <div class="lg:col-span-1">
                   <label for="postal_code" class="block text-sm font-medium text-gray-700 mb-1">Cód. Postal</label>
                   <input type="text" id="postal_code" name="postal_code" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                 </div>
                 <div class="lg:col-span-1">
                   <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                   <input type="tel" id="phone" name="phone" required class="block w-full rounded-xl border-gray-300 bg-gray-50/50 py-3 px-4 text-sm focus:border-primary focus:ring-primary shadow-sm outline-none transition-colors border" />
                 </div>
                 <!-- Hidden country code field -->
                 <input type="hidden" name="country_code" value="ar" />
              </div>
            </div>

            <!-- Checkbox to save new address to account (only shown if logged in and filling new address) -->
            <div id="save-address-checkbox-container" class="hidden items-center gap-2 mt-4 bg-gray-50 p-3 rounded-xl border border-gray-200">
               <input type="checkbox" id="save_address" name="save_address" checked class="w-4 h-4 text-primary focus:ring-primary border-gray-300 rounded cursor-pointer" />
               <label for="save_address" class="text-sm font-medium text-gray-700 cursor-pointer">Guardar esta dirección en mi libreta para futuras compras</label>
            </div>

            <button 
              type="submit" 
              class="w-full sm:w-auto mt-4 relative group inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-bold text-white transition-all duration-300 hover:bg-primary/95 focus:outline-none focus:ring-4 focus:ring-primary/20 shadow-lg shadow-primary/20 hover:shadow-primary/40"
            >
              Continuar a Envío
              <Icon name="tabler:arrow-right" class="w-4 h-4" />
            </button>
          </form>

          <!-- Capa de bloqueo durante la carga -->
          <div id="step-2-loading-overlay" class="absolute inset-0 bg-white/60 backdrop-blur-sm z-20 hidden items-center justify-center rounded-2xl">
            <span class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></span>
          </div>

          <!-- Accordion Summary (Completed State) -->
          <div id="step-2-complete-summary" class="hidden items-center justify-between bg-gray-50 p-4 rounded-xl border border-gray-100">
            <div class="flex flex-col">
               <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-0.5">Dirección</span>
               <span id="summary-address" class="text-sm font-bold text-gray-900 truncate max-w-[200px] sm:max-w-xs">-</span>
            </div>
            <button type="button" class="text-primary text-sm font-bold hover:underline" onclick="window.setActiveStep(2)">
              Editar
            </button>
          </div>
        </article>
        
        <!-- PASO 3: Método de Envío -->
        <article id="step-3-delivery" class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm opacity-50 pointer-events-none transition-all duration-500 relative">
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-xs font-bold leading-none transition-colors" id="step-3-badge">3</span>
            <h2 class="text-lg font-bold text-gray-900">Métodos de Entrega</h2>
          </div>
          
          <form id="form-shipping-method" class="hidden flex-col gap-4">
             <div id="shipping-options-container" class="space-y-3 min-h-[50px]">
               <!-- Se rellena con JS -->
                <div class="flex items-center justify-center py-4 opacity-50 animate-pulse">
                   <span class="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
                </div>
             </div>
             
             <button 
               type="submit" 
               class="w-full sm:w-auto mt-2 relative inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-bold text-white transition-all duration-300 hover:bg-primary/95 focus:outline-none focus:ring-4 focus:ring-primary/20 shadow-lg shadow-primary/20 hover:shadow-primary/40 disabled:opacity-50 disabled:cursor-not-allowed"
             >
               Continuar al Pago
               <Icon name="tabler:arrow-right" class="w-4 h-4" />
             </button>
          </form>

          <!-- Capa de bloqueo durante la carga -->
          <div id="step-3-loading-overlay" class="absolute inset-0 bg-white/60 backdrop-blur-sm z-20 hidden items-center justify-center rounded-2xl">
            <span class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></span>
          </div>

          <!-- Accordion Summary (Completed State) -->
          <div id="step-3-complete-summary" class="hidden items-center justify-between bg-gray-50 p-4 rounded-xl border border-gray-100">
            <div class="flex flex-col">
               <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-0.5">Envío</span>
               <span id="summary-shipping" class="text-sm font-bold text-gray-900 truncate max-w-[200px] sm:max-w-xs">-</span>
            </div>
            <button type="button" class="text-primary text-sm font-bold hover:underline" onclick="window.setActiveStep(3)">
              Editar
            </button>
          </div>
        </article>

        <!-- PASO 4: Pago -->
        <article id="step-4-payment" class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm opacity-50 pointer-events-none transition-all duration-500 relative">
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-xs font-bold leading-none transition-colors" id="step-4-badge">4</span>
            <h2 class="text-lg font-bold text-gray-900">Método de Pago</h2>
          </div>
          
          <form id="form-payment-method" class="hidden flex-col gap-4">
             <div class="p-4 border border-primary bg-primary/5 rounded-xl">
               <div class="flex items-center gap-3 mb-2">
                 <input type="radio" name="payment_method" value="system" class="w-4 h-4 text-primary focus:ring-primary border-gray-300" checked readonly />
                 <span class="block text-sm font-bold text-gray-900">Pago Manual / Transferencia (Prueba)</span>
               </div>
               <p class="text-xs text-gray-600 ml-7">Completa la orden para asegurar tus productos. Te contactaremos con los datos bancarios de Deiman para realizar el depósito o transferencia.</p>
             </div>
             
             <button 
               type="submit" 
               class="w-full mt-4 relative inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-3.5 text-base font-bold text-white transition-all duration-300 hover:bg-primary/90 focus:outline-none focus:ring-4 focus:ring-primary/20 shadow-lg shadow-primary/20 hover:shadow-primary/40"
             >
               Completar Orden Segura
               <Icon name="tabler:shopping-cart-check" class="w-5 h-5" />
             </button>
          </form>

          <!-- Capa de bloqueo durante la carga -->
          <div id="step-4-loading-overlay" class="absolute inset-0 bg-white/60 backdrop-blur-sm z-20 hidden flex-col items-center justify-center rounded-2xl gap-3 text-center">
            <span class="w-8 h-8 border-4 border-gray-900 border-t-transparent rounded-full animate-spin"></span>
            <p class="text-sm font-bold text-gray-900 animate-pulse">Procesando orden segura...</p>
          </div>
        </article>

      </section>

      <!-- Lado Derecho: Resumen de Orden Sidebar Fijado -->
      <section class="lg:col-span-5 2xl:col-span-4 mt-10 lg:mt-0">
        <div class="sticky top-24 bg-gray-50 border border-gray-200 rounded-3xl p-6 shadow-inner">
          <!-- Progress Timeline -->
          <div class="mb-6 flex items-center justify-between relative">
             <div class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-0.5 bg-gray-200 -z-10"></div>
             <div id="timeline-progress-bar" class="absolute left-0 top-1/2 -translate-y-1/2 h-0.5 bg-green-500 -z-10 transition-all duration-500 w-0"></div>
             
             <!-- Steps -->
             <div class="flex flex-col items-center gap-1 bg-gray-50 px-1" id="timeline-step-1">
               <div class="w-6 h-6 rounded-full bg-green-500 text-white flex items-center justify-center shadow-sm ring-2 ring-green-500/30 ring-offset-2 ring-offset-gray-50 transition-all duration-300">
                 <Icon name="tabler:mail" class="w-3.5 h-3.5" />
               </div>
             </div>
             <div class="flex flex-col items-center gap-1 bg-gray-50 px-1" id="timeline-step-2">
               <div class="w-6 h-6 rounded-full bg-white border-2 border-gray-200 text-gray-400 flex items-center justify-center transition-colors duration-300">
                 <Icon name="tabler:map-pin" class="w-3.5 h-3.5" />
               </div>
             </div>
             <div class="flex flex-col items-center gap-1 bg-gray-50 px-1" id="timeline-step-3">
               <div class="w-6 h-6 rounded-full bg-white border-2 border-gray-200 text-gray-400 flex items-center justify-center transition-colors duration-300">
                 <Icon name="tabler:truck" class="w-3.5 h-3.5" />
               </div>
             </div>
             <div class="flex flex-col items-center gap-1 bg-gray-50 px-1" id="timeline-step-4">
               <div class="w-6 h-6 rounded-full bg-white border-2 border-gray-200 text-gray-400 flex items-center justify-center transition-colors duration-300">
                 <Icon name="tabler:credit-card" class="w-3.5 h-3.5" />
               </div>
             </div>
          </div>

          <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center justify-between">
            <span>Resumen del Carrito</span>
            <span class="bg-white px-2 py-0.5 rounded-full text-xs font-black shadow-sm" id="checkout-cart-count">0 art.</span>
          </h3>

          <!-- Items list container -->
          <div id="checkout-items" class="flex flex-col gap-4 max-h-[40vh] overflow-y-auto pr-2 mb-6">
             <div class="flex items-center justify-center py-10 opacity-50 animate-pulse">
                <span class="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
             </div>
          </div>

          <!-- Totals -->
          <div class="border-t border-gray-200 pt-6 space-y-3">
             <div class="flex items-center justify-between text-sm text-gray-500">
               <span>Subtotal</span>
               <span id="checkout-subtotal" class="font-medium text-gray-900">-</span>
             </div>
             <div class="flex items-center justify-between text-sm text-gray-500">
               <span>Envío</span>
               <span id="checkout-shipping" class="font-medium text-gray-500 italic">Pendiente</span>
             </div>
             <div class="flex items-center justify-between text-sm text-gray-500">
               <span>Impuestos</span>
               <span id="checkout-taxes" class="font-medium text-gray-900">-</span>
             </div>
             
             <div class="flex items-center justify-between pt-3 mt-3 border-t border-gray-200">
               <span class="text-base font-bold text-gray-900">Total</span>
               <div class="text-right">
                 <span class="text-[10px] text-gray-400 block font-normal leading-tight">ARS</span>
                 <span id="checkout-total" class="text-2xl font-black text-gray-900">-</span>
               </div>
             </div>
          </div>
          
        </div>
      </section>

    </div>
  </div>
</ShopLayout>

<script>
  import { getCart, updateCartEmail, updateShippingAddress, getShippingOptions, addShippingMethod, initiatePaymentSessions, completeCart } from '~/lib/cart';
  import { getMe, addCustomerAddress } from '~/lib/auth';

  const formatter = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' });

  declare global {
    interface Window {
      setActiveStep: (stepNumber: number) => void;
    }
  }

  const playSuccessSound = () => {
    try {
      // @ts-expect-error - Fallback for Safari
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;
      const ctx = new AudioCtx();
      const playTone = (freq: number, startTime: number, duration: number) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, startTime);
        gain.gain.setValueAtTime(0.3, startTime);
        gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
        osc.start(startTime);
        osc.stop(startTime + duration);
      };
      playTone(600, ctx.currentTime, 0.15);
      playTone(800, ctx.currentTime + 0.15, 0.3);
    } catch (err) {
       // Ignore silent error
       if (err) console.debug('Audio not supported', err);
    }
  };

  window.setActiveStep = (targetStep: number) => {
     const panels = ['step-1-email', 'step-2-shipping', 'step-3-delivery', 'step-4-payment'];
     panels.forEach((panelId, index) => {
        const stepNum = index + 1;
        const el = document.getElementById(panelId);
        const badge = document.getElementById(`step-${stepNum}-badge`);
        const form = el?.querySelector('form');
        const summary = document.getElementById(`step-${stepNum}-complete-summary`);
        
        if (stepNum === targetStep) {
           // Active
           el?.classList.remove('opacity-50', 'pointer-events-none');
           if (badge) badge.className = "flex items-center justify-center w-6 h-6 rounded-full bg-primary text-white text-xs font-bold leading-none ring-2 ring-primary/30 ring-offset-2 ring-offset-white transition-all duration-300";
           
           if (form) form.classList.remove('hidden');
           if (summary) {
              summary.classList.add('hidden');
              summary.classList.remove('flex');
           }
        } else if (stepNum > targetStep) {
           // Future
           el?.classList.add('opacity-50', 'pointer-events-none');
           if (badge) badge.className = "flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-xs font-bold leading-none transition-colors";
           
           if (form) form.classList.remove('hidden');
           if (summary) {
              summary.classList.add('hidden');
              summary.classList.remove('flex');
           }
        } else {
           // Past (Completed) - Accordion collapsed mode
           el?.classList.remove('opacity-50', 'pointer-events-none');
           if (badge) badge.className = "flex items-center justify-center w-6 h-6 rounded-full bg-green-500 text-white text-xs font-bold leading-none transition-colors";
           
           // Ocultar formulario para archivar espacio y mostrar solo info confirmada
           if (form) form.classList.add('hidden');
           if (summary) {
              summary.classList.remove('hidden');
              summary.classList.add('flex');
           }
        }
     });
     updateTimeline(targetStep);
  };

  const setupCheckout = async () => {
    // 1. Cargar datos del carrito en el resumen izquierdo
    const cart = await getCart();
    
    if (!cart || !cart.items || cart.items.length === 0) {
      window.location.href = '/hogar'; // Redirigir si no hay nada
      return;
    }

    // Llenar HTML de items en el resumen
    const itemsContainer = document.getElementById('checkout-items');
    if (itemsContainer) {
      itemsContainer.innerHTML = cart.items.map((item: { thumbnail?: string; quantity: number; product_title?: string; title?: string; variant_title?: string; unit_price: number }) => `
        <div class="flex gap-4 relative group">
          <div class="w-16 h-16 bg-white/50 flex-shrink-0 relative">
            <div class="w-full h-full rounded-xl overflow-hidden border border-gray-200/60">
              ${item.thumbnail 
                ? `<img src="${item.thumbnail}" alt="" class="w-full h-full object-cover mix-blend-multiply" />`
                : `<div class="w-full h-full flex items-center justify-center text-gray-300"><Icon name="tabler:photo" class="w-6 h-6" /></div>`
              }
            </div>
            <span class="absolute -top-1.5 -right-1.5 flex h-5 w-5 items-center justify-center rounded-full bg-gray-500 text-[10px] font-bold text-white shadow-sm ring-2 ring-white z-10">
              ${item.quantity}
            </span>
          </div>
          <div class="flex-1 min-w-0 pr-2 pt-1 flex flex-col">
            <h4 class="text-xs font-bold text-gray-900 truncate leading-tight">${item.product_title || item.title}</h4>
            <p class="text-[10px] text-gray-500 mt-0.5 truncate">${item.variant_title || ''}</p>
            <span class="text-sm font-bold text-primary mt-auto">${formatter.format(item.unit_price)}</span>
          </div>
        </div>
      `).join('');
    }

    const totalCount = cart.items.reduce((sum: number, item: { quantity: number }) => sum + item.quantity, 0);
    const countBadge = document.getElementById('checkout-cart-count');
    if (countBadge) countBadge.textContent = `${totalCount} art.`;

    const els = {
      sub: document.getElementById('checkout-subtotal'),
      tax: document.getElementById('checkout-taxes'),
      ship: document.getElementById('checkout-shipping'),
      total: document.getElementById('checkout-total')
    };

    if (els.sub) els.sub.textContent = formatter.format(cart.subtotal || 0);
    if (els.tax) els.tax.textContent = formatter.format(cart.tax_total || 0);
    if (els.ship && cart.shipping_total) els.ship.textContent = formatter.format(cart.shipping_total);
    if (els.total) els.total.textContent = formatter.format(cart.total || 0);


    // 2. Lógica de Pasos

    // Paso 1: Email
    const emailForm = document.getElementById('form-email') as HTMLFormElement;
    if (emailForm) {
       // Pre-llenar si ya había
       if (cart.email) {
          const emailInput = document.getElementById('email') as HTMLInputElement;
          if (emailInput) emailInput.value = cart.email;
          document.getElementById('summary-email')!.textContent = cart.email;
          window.setActiveStep(2);
       }

       emailForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const p = emailForm.querySelector('button');
          if (p) p.disabled = true;

          const loadingOverlay = document.getElementById('step-1-loading-overlay');
          loadingOverlay?.classList.remove('hidden');
          loadingOverlay?.classList.add('flex');

          const email = (new FormData(emailForm)).get('email') as string;
          try {
             await updateCartEmail(email);
             document.getElementById('summary-email')!.textContent = email;
             playSuccessSound();
             window.setActiveStep(2);
          } catch (err) {
             console.error("Error setting email", err);
             alert("Hubo un error guardando tu correo.");
          } finally {
            if (p) p.disabled = false;
            loadingOverlay?.classList.add('hidden');
            loadingOverlay?.classList.remove('flex');
          }
       });
    }

    // Paso 2: Envío
    const shippingForm = document.getElementById('form-shipping') as HTMLFormElement;
    const savedAddrContainer = document.getElementById('saved-addresses-container');
    const newAddrFields = document.getElementById('new-address-form-fields');
    const saveAddrMeta = document.getElementById('save-address-checkbox-container');
    
    let customerAddresses: Record<string, unknown>[] = [];
    let selectedAddressId: string | null = null;
    let customerIsLoggedIn = false;

    if (shippingForm && cart.email) {
       
       // 1. Check for logged in customer and their addresses
       try {
           const customer = await getMe();
           if (customer) {
               customerIsLoggedIn = true;
               if (customer.addresses && customer.addresses.length > 0) {
                   customerAddresses = customer.addresses;
               }
           }
       } catch {
           /* Ignore silently, user is just guest */
       }

       // Render Addresses Logic
       const renderSavedAddresses = () => {
           if (!savedAddrContainer) return;
           if (customerAddresses.length === 0) {
               selectedAddressId = 'new';
               toggleNewAddressFormVisibility();
               return;
           }
           
           savedAddrContainer.classList.remove('hidden');
           
           const html = customerAddresses.map((addr) => `
               <label class="flex items-start p-4 border rounded-xl cursor-pointer transition-colors ${selectedAddressId === addr.id ? 'border-primary bg-primary/5' : 'border-gray-200 hover:border-primary/50'}">
                   <input type="radio" name="selected_address_id" value="${addr.id}" class="mt-0.5 w-4 h-4 text-primary focus:ring-primary border-gray-300 mr-3" ${selectedAddressId === addr.id ? 'checked' : ''} />
                   <div>
                       <span class="block text-sm font-bold text-gray-900">${addr.first_name} ${addr.last_name}</span>
                       <span class="block text-sm text-gray-500">${addr.address_1} ${addr.address_2 ? ' - ' + addr.address_2 : ''}</span>
                       <span class="block text-xs text-gray-400 mt-0.5">${addr.city}, ${addr.province} (CP: ${addr.postal_code})</span>
                       <span class="block text-xs text-gray-400 font-mono mt-0.5">Tel: ${addr.phone || 'N/A'}</span>
                   </div>
               </label>
           `).join('') + `
               <label class="flex items-center p-4 border rounded-xl cursor-pointer transition-colors border-dashed ${selectedAddressId === 'new' ? 'border-primary bg-primary/5' : 'border-gray-300 hover:border-primary/50'}">
                   <input type="radio" name="selected_address_id" value="new" class="w-4 h-4 text-primary focus:ring-primary border-gray-300 mr-3" ${selectedAddressId === 'new' ? 'checked' : ''} />
                   <span class="text-sm font-bold text-gray-900">Ingresar nueva dirección de envío</span>
               </label>
           `;
           
           savedAddrContainer.innerHTML = html;

           savedAddrContainer.querySelectorAll('input[type="radio"]').forEach(radio => {
               radio.addEventListener('change', (e) => {
                   selectedAddressId = (e.target as HTMLInputElement).value;
                   toggleNewAddressFormVisibility();
                   renderSavedAddresses(); // re-render to update classes
               });
           });
       };

       const toggleNewAddressFormVisibility = () => {
           if (!newAddrFields) return;
           const inputs = newAddrFields.querySelectorAll('input[required], select[required]');
           
           if (selectedAddressId === 'new') {
               newAddrFields.classList.remove('hidden');
               if (customerIsLoggedIn) {
                   saveAddrMeta?.classList.remove('hidden');
                   saveAddrMeta?.classList.add('flex');
               }
               inputs.forEach(el => (el as HTMLInputElement).required = true);
           } else {
               newAddrFields.classList.add('hidden');
               saveAddrMeta?.classList.add('hidden');
               saveAddrMeta?.classList.remove('flex');
               inputs.forEach(el => (el as HTMLInputElement).required = false);
           }
       };

       // Pre-llenar si ya había en el carrito (o seleccionar dirección matcheada)
       if (cart.shipping_address && cart.shipping_address.address_1) {
           const m = cart.shipping_address;
           
           // Intentar match con una direccion guardada
           const matchedSaved = customerAddresses.find(a => 
               a.address_1 === m.address_1 && a.postal_code === m.postal_code
           );

           if (matchedSaved) {
               selectedAddressId = (matchedSaved.id as string);
           } else {
               selectedAddressId = 'new';
               if (m.first_name) (document.getElementById('first_name') as HTMLInputElement).value = m.first_name;
               if (m.last_name) (document.getElementById('last_name') as HTMLInputElement).value = m.last_name;
               if (m.address_1) (document.getElementById('address_1') as HTMLInputElement).value = m.address_1;
               if (m.address_2) (document.getElementById('address_2') as HTMLInputElement).value = m.address_2;
               if (m.city) (document.getElementById('city') as HTMLInputElement).value = m.city;
               if (m.province) (document.getElementById('province') as HTMLSelectElement).value = m.province;
               if (m.postal_code) (document.getElementById('postal_code') as HTMLInputElement).value = m.postal_code;
               if (m.phone) (document.getElementById('phone') as HTMLInputElement).value = m.phone;
           }
           
           if (m.address_1 && m.city) {
             document.getElementById('summary-address')!.textContent = `${m.address_1}, ${m.city}`;
           }
       } else {
           // Default if no previous cart address
           if (customerAddresses.length > 0) {
              selectedAddressId = (customerAddresses[0].id as string);
           } else {
              selectedAddressId = 'new';
           }
       }

       renderSavedAddresses();
       toggleNewAddressFormVisibility();

       shippingForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const p = shippingForm.querySelector('button');
          if (p) p.disabled = true;

          const loadingOverlay = document.getElementById('step-2-loading-overlay');
          loadingOverlay?.classList.remove('hidden');
          loadingOverlay?.classList.add('flex');

          let addressPayload: Record<string, string> = {};
          
          if (selectedAddressId !== 'new') {
              // Extract from saved address list
              const saved = customerAddresses.find(a => a.id === selectedAddressId);
              if (saved) {
                  addressPayload = {
                     first_name: saved.first_name as string,
                     last_name: saved.last_name as string,
                     address_1: saved.address_1 as string,
                     address_2: (saved.address_2 as string) || '',
                     city: saved.city as string,
                     province: saved.province as string,
                     postal_code: saved.postal_code as string,
                     phone: (saved.phone as string) || '',
                     country_code: 'ar'
                  };
              } else {
                  alert("Error al seleccionar la dirección.");
                  if (p) p.disabled = false;
                  loadingOverlay?.classList.add('hidden');
                  loadingOverlay?.classList.remove('flex');
                  return;
              }
          } else {
              // Extract from form
              const formData = new FormData(shippingForm);
              addressPayload = {
                 first_name: formData.get('first_name') as string,
                 last_name: formData.get('last_name') as string,
                 address_1: formData.get('address_1') as string,
                 address_2: formData.get('address_2') as string,
                 city: formData.get('city') as string,
                 province: formData.get('province') as string,
                 postal_code: formData.get('postal_code') as string,
                 phone: formData.get('phone') as string,
                 country_code: formData.get('country_code') as string,
              };

              // Optionally save to customer account
              const saveCheckbox = document.getElementById('save_address') as HTMLInputElement;
              if (customerIsLoggedIn && saveCheckbox && saveCheckbox.checked) {
                  try {
                      await addCustomerAddress(addressPayload);
                  } catch(err) {
                      console.error("No se pudo guardar la dirección en el perfil", err);
                  }
              }
          }

          try {
             await updateShippingAddress(addressPayload);
             document.getElementById('summary-address')!.textContent = `${addressPayload.address_1}, ${addressPayload.city}`;
             playSuccessSound();
             window.setActiveStep(3);
          } catch (err) {
             console.error("Error setting shipping address", err);
             alert("Hubo un error guardando tu dirección de base.");
          } finally {
            if (p) p.disabled = false;
            loadingOverlay?.classList.add('hidden');
            loadingOverlay?.classList.remove('flex');
          }
       });
     }

    // Paso 3: Método de Envío
    const shippingMethodForm = document.getElementById('form-shipping-method') as HTMLFormElement;
    const shippingOptionsContainer = document.getElementById('shipping-options-container');
    
    // Solo podemos fetchear y usar métodos si tenemos un carrito con dirección válida
    if (shippingMethodForm && shippingOptionsContainer && cart.shipping_address) {
       
       let options: { id: string; name: string; amount: number; description?: string }[] = [];
       try {
          options = await getShippingOptions();
       } catch (err) {
          console.error("Error fetching shipping options", err);
       }

       if (!options || options.length === 0) {
          shippingOptionsContainer.innerHTML = `<div class="p-4 bg-orange-50 text-orange-800 text-sm rounded-xl">No hay opciones de envío disponibles para tu dirección.</div>`;
          const btn = shippingMethodForm.querySelector('button');
          if (btn) btn.disabled = true;
       } else {
          // Verificamos si el carrito ya tiene un método seleccionado
          const currentMethodId = cart.shipping_methods && cart.shipping_methods.length > 0 
                                  ? cart.shipping_methods[0].shipping_option_id 
                                  : null;

          shippingOptionsContainer.innerHTML = options.map((opt) => `
            <label class="flex items-center justify-between p-4 border rounded-xl cursor-pointer transition-colors ${currentMethodId === opt.id ? 'border-primary bg-primary/5' : 'border-gray-200 hover:border-primary/50'}">
              <div class="flex items-center gap-3">
                <input type="radio" name="shipping_option_id" value="${opt.id}" class="w-4 h-4 text-primary focus:ring-primary border-gray-300" ${currentMethodId === opt.id ? 'checked' : ''} required />
                <div>
                  <span class="block text-sm font-bold text-gray-900">${opt.name}</span>
                </div>
              </div>
              <span class="text-sm font-bold text-gray-900">${formatter.format(opt.amount)}</span>
            </label>
          `).join('');

          // Si ya teníamos uno, seteamos el texto del acordeón
          if (currentMethodId) {
             const selectedOpt = options.find((o) => o.id === currentMethodId);
             if (selectedOpt) {
                document.getElementById('summary-shipping')!.textContent = `${selectedOpt.name} - ${formatter.format(selectedOpt.amount)}`;
             }
          }

          // Interactividad UI de los labels de radio
          const radios = shippingOptionsContainer.querySelectorAll('input[type="radio"]');
          radios.forEach(radio => {
             radio.addEventListener('change', (e) => {
                shippingOptionsContainer.querySelectorAll('label').forEach(l => l.className = "flex items-center justify-between p-4 border rounded-xl cursor-pointer transition-colors border-gray-200 hover:border-primary/50");
                const target = e.target as HTMLInputElement;
                if (target.checked) {
                   target.closest('label')!.className = "flex items-center justify-between p-4 border rounded-xl cursor-pointer transition-colors border-primary bg-primary/5";
                }
             });
          });
       }

       shippingMethodForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const p = shippingMethodForm.querySelector('button');
          if (p) p.disabled = true;

          const loadingOverlay = document.getElementById('step-3-loading-overlay');
          loadingOverlay?.classList.remove('hidden');
          loadingOverlay?.classList.add('flex');

          const formData = new FormData(shippingMethodForm);
          const optionId = formData.get('shipping_option_id') as string;

          if (!optionId) {
             if (p) p.disabled = false;
             loadingOverlay?.classList.add('hidden');
             loadingOverlay?.classList.remove('flex');
             return;
          }

          try {
             await addShippingMethod(optionId);
             
             // Actualizar texto en Acordeón
             const selectedOpt = options.find((o) => o.id === optionId);
             if (selectedOpt) {
                document.getElementById('summary-shipping')!.textContent = `${selectedOpt.name} - ${formatter.format(selectedOpt.amount)}`;
             }
             
             // Actualizar importes en sidebar (re-buscando total)
             const newCart = await getCart();
             if (newCart) {
                const sub = document.getElementById('checkout-subtotal');
                const ship = document.getElementById('checkout-shipping');
                const tax = document.getElementById('checkout-taxes');
                const total = document.getElementById('checkout-total');
                if (sub) sub.textContent = formatter.format(newCart.subtotal || 0);
                if (ship) { ship.textContent = formatter.format(newCart.shipping_total || 0); ship.classList.remove('italic', 'text-gray-500'); ship.classList.add('text-gray-900'); }
                if (tax) tax.textContent = formatter.format(newCart.tax_total || 0);
                if (total) total.textContent = formatter.format(newCart.total || 0);
             }

             // Iniciar sesiones de pago ahora que tenemos método de envío
             try {
                 await initiatePaymentSessions();
                 console.log("Sesiones de pago instanciadas (al guardar envío)");
             } catch(err) {
                 console.error("Error iniciando pago:", err);
             }

             playSuccessSound();
             window.setActiveStep(4);
          } catch (err) {
             console.error("Error adding shipping method", err);
             alert("Hubo un error guardando tu método de envío.");
          } finally {
             if (p) p.disabled = false;
             loadingOverlay?.classList.add('hidden');
             loadingOverlay?.classList.remove('flex');
          }
       });
    }

    // Paso 4: Pago (Initiate Session on display & submit)
    const paymentForm = document.getElementById('form-payment-method') as HTMLFormElement;
    
    if (paymentForm) {
       // Setup payment sessions on load if shipping exists
       if (cart.shipping_methods && cart.shipping_methods.length > 0) {
           try {
               await initiatePaymentSessions();
               console.log("Sesiones de pago instanciadas en carga.");
           } catch (err) {
               console.error("No se pudo iniciar sesiones de pago en background", err);
           }
       }

       paymentForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const p = paymentForm.querySelector('button');
          if (p) p.disabled = true;

          const loadingOverlay = document.getElementById('step-4-loading-overlay');
          loadingOverlay?.classList.remove('hidden');
          loadingOverlay?.classList.add('flex');

          try {
             // Fallback salvavidas por las dudas aseguramos sesion activa
             await initiatePaymentSessions();
             
             const order = await completeCart();
             if (order && order.id) {
                // Redirigimos a la Order Success Page
                window.location.href = `/hogar/order/${order.id}`;
             }
          } catch (err) {
             console.error("Error completando la orden", err);
             alert("Hubo un error procesando tu pago u orden.");
             if (p) p.disabled = false;
             loadingOverlay?.classList.add('hidden');
             loadingOverlay?.classList.remove('flex');
          }
       });
    }

  };

  const updateTimeline = (activeStep: number) => {
     const bar = document.getElementById('timeline-progress-bar');
     if (bar) {
       const percentages = ['0%', '33%', '66%', '100%'];
       bar.style.width = percentages[activeStep - 1] || '0%';
     }

     for(let i = 1; i <= 4; i++) {
        const iconContainer = document.querySelector(`#timeline-step-${i} div`);
        if (!iconContainer) continue;
        
        if (i < activeStep) {
           // Completed (check icon)
           iconContainer.className = "w-6 h-6 rounded-full bg-green-500 text-white flex items-center justify-center shadow-sm transition-all duration-300";
           iconContainer.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M5 12l5 5l10 -10"></path></svg>';
        } else if (i === activeStep) {
           // Active (ring)
           iconContainer.className = "w-6 h-6 rounded-full bg-green-500 text-white flex items-center justify-center shadow-sm transition-all duration-300 ring-2 ring-green-500/30 ring-offset-2 ring-offset-gray-50";
        } else {
           // Pending (gray border)
           iconContainer.className = "w-6 h-6 rounded-full bg-white border-2 border-gray-200 text-gray-400 flex items-center justify-center transition-colors duration-300";
        }
     }
  };

  // Make sure we re-run and listen to Client-Router if enabled.
  document.addEventListener('astro:page-load', setupCheckout);
</script>
