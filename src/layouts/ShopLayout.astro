---
import Layout from '~/layouts/Layout.astro';
import ShopHeader from '~/components/widgets/ShopHeader.astro';
import ShopFooter from '~/components/widgets/ShopFooter.astro';
import SideCart from '~/components/hogar/SideCart.astro';
import SearchModal from '~/components/hogar/SearchModal.astro';
import { shopHeaderData, shopFooterData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
const pathname = Astro.url.pathname;
const isCheckout = pathname.includes('/checkout');
const isTienda = pathname.startsWith('/hogar/tienda');
---

<Layout metadata={metadata}>
  <slot name="header">
    <ShopHeader {...shopHeaderData} isSticky />
  </slot>

  <main class="min-h-screen bg-slate-50 relative">    
    {isTienda && 
      <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-100">
        <div class="absolute inset-0 w-full h-full bg-[url('/images/backgrounds/background-mappet.svg')] bg-[length:1920px_3115px] bg-repeat animate-slide-bg"></div>
      </div>
    }

    <!-- Aquí dentro vivirá toda la aplicación de E-Commerce -->
    <div class="relative z-10">
      <slot />
    </div>
  </main>
  
  <slot name="footer">
    <ShopFooter {...shopFooterData} />
  </slot>

  <!-- SideCart Component Global -->
  {!isCheckout && <SideCart />}

  <!-- Search Modal Component Global -->
  {!isCheckout && <SearchModal />}

  <!-- Script que inicializa y re-evalúa silenciosamente la región del usuario -->
  <script>
    import { regionIdStore, cartIdStore } from '~/store/client';
    import { medusaClient } from '~/lib/medusa';

    async function initializeRegion() {
      try {
        const { regions } = await medusaClient.store.region.list();
        if (regions && regions.length > 0) {
          const currentRegionId = regionIdStore.get();
          // Verificamos si la región guardada en memoria todavía existe en el dashboard
          const isRegionValid = regions.some((r) => r.id === currentRegionId);

          if (!currentRegionId || !isRegionValid) {
            console.warn("⚠️ Región no encontrada o desactualizada. Re-sincronizando...");
            // Asigna la primera región por defecto (ej. Argentina)
            regionIdStore.set(regions[0].id);
            // Si la región cambió, el carrito viejo es incompatible. Lo matamos para que nazca uno nuevo:
            cartIdStore.set(undefined);
            
            console.log("🛒 Nueva Región E-Commerce configurada:", regions[0].name);
            
            // Si estamos en el checkout y nos quedamos sin carrito, redirigir a Home
            if (window.location.pathname.includes('/checkout')) {
               window.location.href = '/hogar';
            }
          }
        }
      } catch (error) {
        console.error("🛒 Error obteniendo las regiones del servidor:", error);
      }
    }

    // Ejecutar cuando el DOM esté listo o Astro cargue la página
    document.addEventListener("DOMContentLoaded", initializeRegion);
    document.addEventListener("astro:page-load", initializeRegion); // Por si usa ViewTransitions
  </script>
</Layout>
