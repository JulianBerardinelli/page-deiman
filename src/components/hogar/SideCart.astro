---
import { Icon } from 'astro-icon/components';
---

<!-- Overlay Oscuro -->
<div 
  id="sidecart-overlay" 
  class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[100] opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Drawer Panel -->
<div 
  id="sidecart-panel" 
  class="fixed top-0 right-0 h-full w-full max-w-sm bg-white shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
>
  <!-- Cabecera del Carrito -->
  <div class="px-6 py-4 flex items-center justify-between border-b border-gray-100">
    <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
      <Icon name="tabler:shopping-cart" class="w-5 h-5" />
      Mi Carrito
    </h2>
    <button id="close-sidecart-btn" class="p-2 text-gray-400 hover:text-gray-700 hover:bg-gray-100 rounded-full transition-colors">
      <Icon name="tabler:x" class="w-5 h-5" />
    </button>
  </div>

  <!-- Contenedor Dinámico de Items -->
  <div id="sidecart-items" class="flex-1 overflow-y-auto p-6 flex flex-col gap-4">
    <div class="flex flex-col items-center justify-center h-full text-gray-400 space-y-4">
      <Icon name="tabler:shopping-cart-x" class="w-12 h-12 opacity-50" />
      <p class="text-sm font-medium">Tu carrito está vacío.</p>
      <button id="continue-shopping-btn" class="mt-2 text-sm text-primary font-bold hover:underline">
        Continuar comprando
      </button>
    </div>
  </div>

  <!-- Resumen y Footer (Solo visible si hay items) -->
  <div id="sidecart-footer" class="border-t border-gray-100 p-6 bg-slate-50 hidden">
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm font-semibold text-gray-500">Subtotal</span>
      <span id="sidecart-subtotal" class="text-xl font-black text-gray-900">$0.00</span>
    </div>
    <p class="text-[10px] text-gray-500 mb-4">*Los costos de envío e impuestos se calculan en el checkout.</p>
    <a 
      id="proceed-checkout-btn"
      href="/hogar/checkout" 
      class="w-full flex items-center justify-center gap-2 bg-primary text-white font-bold py-3.5 px-4 rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 hover:-translate-y-0.5 transition-all duration-300"
    >
      Proceder al Pago
      <Icon name="tabler:arrow-right" class="w-4 h-4" />
    </a>
  </div>
</div>

<script>
  import { isCartOpenStore, cartDataStore } from '~/store/client';
  import { getCart, removeCartItem, updateCartItem } from '~/lib/cart';

  const setupSideCart = () => {
    const overlay = document.getElementById('sidecart-overlay');
    const panel = document.getElementById('sidecart-panel');
    const closeBtn = document.getElementById('close-sidecart-btn');
    const itemsContainer = document.getElementById('sidecart-items');
    const footer = document.getElementById('sidecart-footer');
    const subtotalEl = document.getElementById('sidecart-subtotal');
    const continueBtn = document.getElementById('continue-shopping-btn');
    const proceedBtn = document.getElementById('proceed-checkout-btn');

    if (!overlay || !panel) return;

    // Suscribirse a los cambios de estado local
    isCartOpenStore.subscribe((isOpen) => {
      if (isOpen) {
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');
        panel.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
        renderCartUI(); // Fetch y render cuando se abre
      } else {
        overlay.classList.remove('opacity-100');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        panel.classList.add('translate-x-full');
        document.body.style.overflow = '';
      }
    });

    // Suscribirse a los datos del carrito para re-renderizar reactivamente
    cartDataStore.subscribe((cartData) => {
      // Solo nos interesa re-renderizar si el carrito de verdad está abierto y los datos cambiaron
      if (isCartOpenStore.get() && cartData) {
         renderCartUI(false); // Renderizar sin forzar spinner
      }
    });

    // Cerrar el carrito
    const closeCart = () => isCartOpenStore.set(false);
    
    closeBtn?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', closeCart);
    continueBtn?.addEventListener('click', closeCart);
    proceedBtn?.addEventListener('click', closeCart);

    // Formateador de moneda
    const formatter = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' });

    // Renderizar y mutar lógica
    const renderCartUI = async (forceFetch = false) => {
      // 1. Mostrar estado de carga base
      if (itemsContainer && forceFetch) {
        // En un update forzado inicial completo podemos mostrar el spinner
        itemsContainer.innerHTML = `
          <div class="flex items-center justify-center py-10 opacity-50 animate-pulse">
            <span class="w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
          </div>
        `;
      }
      
      const cart = await getCart(forceFetch);
      
      if (!cart || !cart.items || cart.items.length === 0) {
        // Carrito Vacio
        if (itemsContainer) {
          itemsContainer.innerHTML = `
            <div class="flex flex-col items-center justify-center h-full text-gray-400 space-y-4 py-10">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 10l5 -6l5 6" /><path d="M21 10l-2 8a2 2.5 0 0 1 -2 2H7a2 2.5 0 0 1 -2 -2l-2 -8Z" /><circle cx="12" cy="15" r="2" /></svg>
              <p class="text-sm font-medium">Tu carrito está vacío.</p>
            </div>
          `;
        }
        if (footer) footer.classList.add('hidden');
        
        // Disparar evento custom para actualizar el contador del header
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: 0 } }));
        return;
      }

      // Si hay Items
      if (footer) footer.classList.remove('hidden');
      if (subtotalEl) subtotalEl.textContent = formatter.format(cart.total || 0);

      // Calcular cantidad real sumando el atributo "quantity" de todas las líneas
      const totalCount = cart.items.reduce((sum, item) => sum + item.quantity, 0);
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: totalCount } }));

      // Map through items
      const htmlList = cart.items.map((item) => `
        <div class="flex gap-4 py-4 border-b border-gray-100 last:border-0 relative group">
          <div class="w-20 h-20 rounded-xl overflow-hidden bg-slate-100 flex-shrink-0 border border-gray-200/60">
            ${item.thumbnail 
              ? `<img src="${item.thumbnail}" alt="${item.title}" class="w-full h-full object-cover mix-blend-multiply" />`
              : `<div class="w-full h-full flex items-center justify-center text-gray-300"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></div>`
            }
          </div>
          <div class="flex-1 min-w-0 pr-6">
            <h3 class="text-sm font-bold text-gray-900 truncate">${item.product_title || item.title}</h3>
            ${item.variant_title ? `<p class="text-xs text-gray-500 mb-2 truncate">${item.variant_title}</p>` : ''}
            
            <div class="flex items-center justify-between mt-auto">
              <span class="text-sm font-bold text-primary">${formatter.format(item.unit_price)}</span>
              
              <!-- Controles de Cantidad -->
              <div class="flex items-center bg-gray-50 rounded-lg border border-gray-200 px-1 py-0.5">
                <button data-action="decrease" data-id="${item.id}" data-qty="${item.quantity}" class="qty-btn w-6 h-6 flex items-center justify-center text-gray-500 hover:text-black hover:bg-white rounded transition-colors">-</button>
                <span class="w-6 text-center text-xs font-semibold text-gray-900">${item.quantity}</span>
                <button data-action="increase" data-id="${item.id}" data-qty="${item.quantity}" class="qty-btn w-6 h-6 flex items-center justify-center text-gray-500 hover:text-black hover:bg-white rounded transition-colors">+</button>
              </div>
            </div>
          </div>
          
          <!-- Delete button -->
          <button data-action="delete" data-id="${item.id}" class="delete-btn absolute top-4 right-0 text-gray-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" /><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" /><path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" /></svg>
          </button>
        </div>
      `).join('');

      if (itemsContainer) itemsContainer.innerHTML = htmlList;

      // Attach event listeners for dynamic buttons inside the cart
      itemsContainer?.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const isIncrease = btn.getAttribute('data-action') === 'increase';
          const lineId = btn.getAttribute('data-id');
          const currentQty = parseInt(btn.getAttribute('data-qty') || "1");
          
          if (!lineId) return;

          const newQty = isIncrease ? currentQty + 1 : Math.max(0, currentQty - 1);

          // --- Optimistic UI Update para feedback instantáneo ---
          btn.setAttribute('disabled', 'true');
          const qtySpan = btn.parentElement?.querySelector('span');
          if (qtySpan) qtySpan.textContent = newQty.toString();
          
          const row = btn.closest('.group') as HTMLElement;
          if (newQty === 0 && row) row.style.opacity = '0.4';

          try {
            if (newQty === 0) {
              await removeCartItem(lineId);
            } else {
              await updateCartItem({ lineId, quantity: newQty });
            }
            await renderCartUI(); // Reload UI from cache
          } catch (error) {
            console.error('Error updating cart qty:', error);
            // Revert optimistic si falla
            if (qtySpan) qtySpan.textContent = currentQty.toString();
            if (newQty === 0 && row) row.style.opacity = '1';
          } finally {
            btn.removeAttribute('disabled');
          }
        });
      });

      itemsContainer?.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const lineId = btn.getAttribute('data-id');
          if (!lineId) return;

          btn.setAttribute('disabled', 'true');
          const row = btn.closest('.group') as HTMLElement;
          if (row) row.style.opacity = '0.4';

          try {
            await removeCartItem(lineId);
            await renderCartUI(); // Reload UI from cache
          } catch (error) {
            console.error('Error deleting cart item:', error);
            if (row) row.style.opacity = '1';
          } finally {
            btn.removeAttribute('disabled');
          }
        });
      });
    };
  };

  // Cargar en Astro transitions
  document.addEventListener('astro:page-load', setupSideCart);
</script>
