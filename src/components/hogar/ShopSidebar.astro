---
import { Icon } from 'astro-icon/components';

export interface Props {
  categories: { name: string; handle: string; id: string }[];
  collections?: { title: string; handle: string; id: string }[];
  currentCategoryHandle?: string | null;
}

const { categories, collections = [], currentCategoryHandle = null } = Astro.props;

const getCollectionStyle = (handle: string) => {
  switch(handle?.toLowerCase()) {
    case 'salados': return 'bg-[#ffebd2] text-[#9c4221] peer-checked:bg-[#f5a524] peer-checked:text-white';
    case 'dulces': return 'bg-[#fee7ef] text-[#970233] peer-checked:bg-[#f31260] peer-checked:text-white';
    case 'frutales': return 'bg-[#e8fbf0] text-[#065b27] peer-checked:bg-[#17c964] peer-checked:text-white';
    case 'aromaticos': return 'bg-[#f4e8ff] text-[#3b096c] peer-checked:bg-[#7828c8] peer-checked:text-white';
    default: return 'bg-gray-100 text-gray-700 peer-checked:bg-gray-800 peer-checked:text-white';
  }
}

const getCollectionAvatar = (handle: string) => {
  switch(handle?.toLowerCase()) {
    case 'salados': return 'https://images.unsplash.com/photo-1621506289937-a8e4df240d0b?w=100&q=80&fit=crop';
    case 'dulces': return 'https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=100&q=80&fit=crop';
    case 'frutales': return 'https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=100&q=80&fit=crop';
    case 'aromaticos': return 'https://images.unsplash.com/photo-1596040033229-a9821ebd058d?w=100&q=80&fit=crop';
    default: return 'https://images.unsplash.com/photo-1550581190-9c1c48d21d6c?w=100&q=80&fit=crop';
  }
}
---

<aside class="w-full lg:w-1/4 relative">
  <!-- Botón Mobile Toggle Filters -->
  <div class="lg:hidden flex items-center justify-between bg-white p-4 rounded-xl border border-gray-200 mb-6 shadow-sm">
    <span class="font-bold text-gray-900 flex items-center gap-2">
      <Icon name="tabler:filter" class="w-5 h-5 text-primary" />
      Filtros
    </span>
    <button id="open-filters-btn" class="text-sm font-medium text-white bg-primary px-4 py-1.5 rounded-lg shadow-sm">
      Mostrar
    </button>
  </div>

  <!-- Overlay de fondo oscuro para Mobile -->
  <div id="filters-overlay" class="fixed inset-0 bg-black/50 z-[90] hidden lg:hidden backdrop-blur-sm transition-opacity opacity-0 pointer-events-none"></div>

  <!-- Contenedor Principal de Filtros (Drawer en Mobile, Sticky en Desktop) -->
  <div id="filters-drawer" class="fixed inset-y-0 right-0 z-[100] w-[280px] sm:w-[320px] bg-white h-[100dvh] overflow-y-auto transform translate-x-full transition-transform duration-300 ease-in-out lg:translate-x-0 lg:static lg:h-auto lg:w-full lg:bg-white/90 lg:backdrop-blur-md lg:p-6 lg:rounded-2xl lg:shadow-[0_8px_30px_rgb(0,0,0,0.04)] lg:border lg:border-gray-100 flex flex-col custom-scrollbar pb-24 lg:pb-0">
    
    <!-- Encabezado Mobile (Oculto en Desktop) -->
    <div class="flex lg:hidden items-center justify-between p-5 border-b border-gray-100 bg-white sticky top-0 z-20 shadow-sm">
      <span class="text-lg font-black text-gray-900 tracking-tight flex items-center gap-2">
        <Icon name="tabler:adjustments-horizontal" class="w-5 h-5 text-primary" />
        Filtros
      </span>
      <button id="close-filters-btn" class="p-2 rounded-full bg-white text-gray-500 hover:text-red-500 hover:bg-red-50 transition-colors shadow-sm border border-gray-200">
        <Icon name="tabler:x" class="w-5 h-5" />
      </button>
    </div>

    <div class="p-5 lg:p-0">
      <h2 class="hidden lg:flex text-lg font-bold text-gray-900 mb-6 items-center gap-2 border-b border-gray-100 pb-4">
        <Icon name="tabler:adjustments-horizontal" class="w-5 h-5 text-primary" />
        Filtros
      </h2>
    
    <div class="space-y-6">
      
      <!-- Presentación (Líquidos / Polvo) -->
      <div>
        <h3 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-3">Presentación</h3>
        <div class="space-y-2">
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="checkbox" name="type-filter" value="liquido" class="w-4 h-4 text-primary bg-gray-50 border-gray-300 rounded focus:ring-primary focus:ring-2 transition-colors cursor-pointer" />
            <span class="text-sm font-medium text-gray-600 group-hover:text-primary transition-colors">Líquidos</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="checkbox" name="type-filter" value="polvo" class="w-4 h-4 text-primary bg-gray-50 border-gray-300 rounded focus:ring-primary focus:ring-2 transition-colors cursor-pointer" />
            <span class="text-sm font-medium text-gray-600 group-hover:text-primary transition-colors">En Polvo</span>
          </label>
        </div>
      </div>

      <!-- Categorías -->
      <div class="pt-5 border-t border-gray-100">
        <h3 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-3">Líneas / Categorías</h3>
        {categories.length > 0 ? (
          currentCategoryHandle === null ? (
            // Modo "Tienda General": Checkboxes para filtrado JS in-situ
            <div class="space-y-2">
              {categories.map((cat) => (
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" name="category-filter" value={cat.id} class="w-4 h-4 text-primary bg-gray-50 border-gray-300 rounded focus:ring-primary focus:ring-2 transition-colors cursor-pointer" />
                  <span class="text-sm font-medium text-gray-600 group-hover:text-primary transition-colors">{cat.name}</span>
                </label>
              ))}
            </div>
          ) : (
            // Modo "Categoría Específica": Enlaces a las otras categorías
            <ul class="space-y-3">
              {categories.map((cat) => (
                <li>
                  <a href={`/hogar/categorias/${cat.handle}`} class={`flex items-center gap-3 cursor-pointer group transition-transform hover:translate-x-1 duration-300 ${cat.handle === currentCategoryHandle ? 'font-bold text-primary translate-x-1' : ''}`}>
                    <Icon name="tabler:category" class={`w-4 h-4 transition-colors ${cat.handle === currentCategoryHandle ? 'text-primary' : 'text-gray-300 group-hover:text-primary'}`} />
                    <span class={`text-sm transition-colors ${cat.handle === currentCategoryHandle ? 'text-primary font-bold' : 'text-gray-600 font-medium group-hover:text-primary'}`}>{cat.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          )
        ) : (
          <p class="text-xs text-gray-500 italic">No hay categorías disponibles.</p>
        )}
      </div>

      <!-- Colecciones (Badges / Chips) -->
      <div class="pt-5 border-t border-gray-100">
        <h3 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-3">Colecciones</h3>
        {collections.length > 0 ? (
          <div class="flex flex-wrap gap-2">
            {collections.map((col) => {
              const styleBase = getCollectionStyle(col.handle);
              const avatarUrl = getCollectionAvatar(col.handle);
              return (
              <label class="cursor-pointer group relative block">
                <input type="checkbox" name="collection-filter" value={col.id} class="peer sr-only" />
                
                <div class={`inline-flex items-center gap-1.5 h-8 p-1 pr-3 rounded-full text-xs font-semibold transition-all duration-300 select-none
                            ${styleBase} hover:opacity-80
                            [&_.close-icon]:hidden peer-checked:[&_.close-icon]:flex
                            peer-checked:[&_.avatar-icon]:hidden`}>
                  
                  {/* Close Icon (Visible sólo cuando está seleccionado, a la izquierda) */}
                  <div class="close-icon items-center justify-center w-6 h-6 rounded-full bg-black/20 text-white transition-colors">
                    <Icon name="tabler:x" class="w-3.5 h-3.5" />
                  </div>

                  {/* Avatar */}
                  <div class="avatar-icon w-6 h-6 rounded-full overflow-hidden flex-shrink-0 bg-white shadow-sm flex items-center justify-center">
                    <img src={avatarUrl} alt={col.title} class="w-full h-full object-cover" loading="lazy" />
                  </div>

                  <!-- Label -->
                  <span>{col.title}</span>
                </div>
              </label>
            )})}
          </div>
        ) : (
          <p class="text-xs text-gray-500 italic">No hay colecciones disponibles.</p>
        )}
      </div>

      <!-- Precio Rango -->
      <div class="pt-5 border-t border-gray-100">
        <h3 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-3">Precio</h3>
        <div class="flex items-center gap-2">
          <div class="relative w-full">
            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 text-xs">$</span>
            <input id="price-min" type="number" placeholder="Min" class="w-full pl-6 pr-2 py-1.5 text-xs border border-gray-200 rounded-md focus:ring-1 focus:ring-primary/50 focus:border-primary outline-none transition-shadow" />
          </div>
          <span class="text-gray-400 text-xs">-</span>
          <div class="relative w-full">
            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-400 text-xs">$</span>
            <input id="price-max" type="number" placeholder="Max" class="w-full pl-6 pr-2 py-1.5 text-xs border border-gray-200 rounded-md focus:ring-1 focus:ring-primary/50 focus:border-primary outline-none transition-shadow" />
          </div>
        </div>
        <button id="apply-price-btn" class="w-full mt-3 bg-primary hover:bg-primary/90 text-white shadow-md shadow-primary/20 hover:-translate-y-0.5 text-xs font-bold py-2 rounded-lg transition-all cursor-pointer">
          Aplicar precio
        </button>
      </div>

      <!-- Limpiar Filtros -->
      <div class="pt-3 pb-8 lg:pb-0">
        {currentCategoryHandle === null ? (
          <button id="reset-filters-btn" class="flex items-center justify-center w-full gap-2 text-xs font-bold text-gray-500 hover:text-red-600 py-2 border border-transparent hover:border-red-100 hover:bg-red-50 rounded-md transition-all cursor-pointer">
            <Icon name="tabler:x" class="w-4 h-4" />
            Limpiar Todo
          </button>
        ) : (
          <a href="/hogar/tienda" class="flex items-center justify-center w-full gap-2 text-xs font-bold text-gray-500 hover:text-red-600 py-2 border border-transparent hover:border-red-100 hover:bg-red-50 rounded-md transition-all cursor-pointer">
            <Icon name="tabler:x" class="w-4 h-4" />
            Limpiar Filtros
          </a>
        )}
      </div>

    </div>
    </div>
  </div>
</aside>

<script>
  document.addEventListener("astro:page-load", () => {
    const openDrawerBtn = document.getElementById("open-filters-btn");
    const closeDrawerBtn = document.getElementById("close-filters-btn");
    const drawer = document.getElementById("filters-drawer");
    const overlay = document.getElementById("filters-overlay");

    const sortSelect = document.getElementById("sort-select") as HTMLSelectElement | null;
    const priceMin = document.getElementById("price-min") as HTMLInputElement | null;
    const priceMax = document.getElementById("price-max") as HTMLInputElement | null;
    const applyPriceBtn = document.getElementById("apply-price-btn");
    const resetBtn = document.getElementById("reset-filters-btn");
    const typeCheckboxes = document.querySelectorAll('input[name="type-filter"]') as NodeListOf<HTMLInputElement>;
    const categoryCheckboxes = document.querySelectorAll('input[name="category-filter"]') as NodeListOf<HTMLInputElement>;
    const collectionCheckboxes = document.querySelectorAll('input[name="collection-filter"]') as NodeListOf<HTMLInputElement>;
    const grids = document.querySelectorAll(".product-grid");

    // Lógica Drawer Mobile
    const toggleDrawer = (open?: boolean) => {
      if(!drawer || !overlay) return;
      const isCurrentlyOpen = drawer.classList.contains("translate-x-0");
      const shouldOpen = open !== undefined ? open : !isCurrentlyOpen;
      
      if(!shouldOpen) {
        // Cerrar
        drawer.classList.remove("translate-x-0");
        drawer.classList.add("translate-x-full");
        overlay.classList.remove("opacity-100", "pointer-events-auto");
        overlay.classList.add("opacity-0", "pointer-events-none");
        setTimeout(() => overlay.classList.add("hidden"), 300);
        document.body.style.overflow = "";
      } else {
        // Abrir
        overlay.classList.remove("hidden");
        // Timeout minimo para forzar el repintado antes de cambiar opacidad
        setTimeout(() => {
          overlay.classList.remove("opacity-0", "pointer-events-none");
          overlay.classList.add("opacity-100", "pointer-events-auto");
          drawer.classList.remove("translate-x-full");
          drawer.classList.add("translate-x-0");
        }, 10);
        document.body.style.overflow = "hidden";
      }
    };

    openDrawerBtn?.addEventListener("click", () => toggleDrawer(true));
    closeDrawerBtn?.addEventListener("click", () => toggleDrawer(false));
    overlay?.addEventListener("click", () => toggleDrawer(false));

    const getCheckedValues = (checkboxes: NodeListOf<HTMLInputElement>) => {
      return Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
    };

    let currentPage = 1;
    const itemsPerPage = 20;

    const renderPagination = (totalPages: number, gridContainer: Element) => {
      // Find the pagination container within the grid's parent
      const wrapper = gridContainer.closest('.flex-col');
      const paginationNav = wrapper?.querySelector('nav[aria-label="Paginación de productos"]');
      
      // Get the container wrapping the nav
      const paginationContainer = paginationNav?.closest('.flex.justify-center.w-full');

      if (!paginationContainer || !paginationNav || totalPages <= 1) {
        if (paginationContainer) (paginationContainer as HTMLElement).style.display = 'none';
        return;
      }

      (paginationContainer as HTMLElement).style.display = 'flex';
      paginationNav.innerHTML = ''; // Clear current buttons

      // Botón Anterior
      const prevBtn = document.createElement('button');
      prevBtn.className = `flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl transition-colors ${currentPage === 1 ? 'bg-transparent text-gray-400 cursor-not-allowed' : 'bg-transparent text-gray-700 hover:bg-gray-100 cursor-pointer'}`;
      prevBtn.disabled = currentPage === 1;
      prevBtn.setAttribute('aria-label', 'Página anterior');
      prevBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M15 6l-6 6l6 6"></path></svg>';
      if (currentPage > 1) {
        prevBtn.addEventListener('click', () => { currentPage--; filterAndSort(); window.scrollTo({top: 0, behavior: 'smooth'}); });
      }
      paginationNav.appendChild(prevBtn);

      // Botones de Páginas (Simplección para evitar demasiados botones si hay muchas págs)
      let startPage = Math.max(1, currentPage - 1);
      let endPage = Math.min(totalPages, currentPage + 1);

      if (currentPage === 1) endPage = Math.min(3, totalPages);
      if (currentPage === totalPages) startPage = Math.max(1, totalPages - 2);

      // Add First Page and dots if needed
      if (startPage > 1) {
        const firstBtn = createPageBtn(1, currentPage);
        firstBtn.addEventListener('click', () => { currentPage = 1; filterAndSort(); window.scrollTo({top: 0, behavior: 'smooth'}); });
        paginationNav.appendChild(firstBtn);
        if (startPage > 2) {
          const dots = document.createElement('span');
          dots.className = "flex items-center justify-center w-7 h-9 text-gray-400 font-bold select-none";
          dots.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M5 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path><path d="M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path><path d="M19 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path></svg>';
          paginationNav.appendChild(dots);
        }
      }

      for (let i = startPage; i <= endPage; i++) {
        const btn = createPageBtn(i, currentPage);
        btn.addEventListener('click', () => { currentPage = i; filterAndSort(); window.scrollTo({top: 0, behavior: 'smooth'}); });
        paginationNav.appendChild(btn);
      }

      // Add Last Page and dots if needed
      if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
          const dots = document.createElement('span');
          dots.className = "flex items-center justify-center w-7 h-9 text-gray-400 font-bold select-none";
          dots.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M5 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path><path d="M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path><path d="M19 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path></svg>';
          paginationNav.appendChild(dots);
        }
        const lastBtn = createPageBtn(totalPages, currentPage);
        lastBtn.addEventListener('click', () => { currentPage = totalPages; filterAndSort(); window.scrollTo({top: 0, behavior: 'smooth'}); });
        paginationNav.appendChild(lastBtn);
      }

      // Botón Siguiente
      const nextBtn = document.createElement('button');
      nextBtn.className = `flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl transition-colors ${currentPage === totalPages ? 'bg-transparent text-gray-400 cursor-not-allowed' : 'bg-transparent text-gray-700 hover:bg-gray-100 cursor-pointer'}`;
      nextBtn.disabled = currentPage === totalPages;
      nextBtn.setAttribute('aria-label', 'Página siguiente');
      nextBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M9 6l6 6l-6 6"></path></svg>';
      if (currentPage < totalPages) {
        nextBtn.addEventListener('click', () => { currentPage++; filterAndSort(); window.scrollTo({top: 0, behavior: 'smooth'}); });
      }
      paginationNav.appendChild(nextBtn);
    };

    const createPageBtn = (page: number, current: number) => {
      const btn = document.createElement('button');
      if (page === current) {
        btn.className = "flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-primary text-white font-bold text-sm shadow-[0_4px_14px_0_rgb(0,129,188,0.39)] transition-transform hover:-translate-y-0.5 cursor-pointer";
        btn.setAttribute('aria-current', 'page');
      } else {
        btn.className = "flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-700 hover:bg-gray-100 font-medium text-sm transition-colors cursor-pointer";
      }
      btn.textContent = String(page);
      return btn;
    };

    const filterAndSort = (resetPage = false) => {
      if (resetPage) currentPage = 1;

      grids.forEach(grid => {
        const cards = Array.from(grid.querySelectorAll(".product-card")) as HTMLElement[];
        const minStr = priceMin?.value || "";
        const maxStr = priceMax?.value || "";
        const min = minStr ? parseFloat(minStr) : 0;
        const max = maxStr ? parseFloat(maxStr) : Infinity;
        const sortValue = sortSelect?.value || "Recomendados";
        const selectedTypes = getCheckedValues(typeCheckboxes);
        const selectedCategories = getCheckedValues(categoryCheckboxes);
        const selectedCollections = getCheckedValues(collectionCheckboxes);

        // Ocultar todos por defecto para el calculo
        cards.forEach(card => card.style.display = "none");

        const matchingCards = cards.filter(card => {
          const price = parseFloat(card.dataset.price || "0");
          const type = card.dataset.type || "otro";
          const category = card.dataset.category || "none";
          const collection = card.dataset.collection || "none";
          
          const passPrice = price >= min && price <= max;
          const passType = selectedTypes.length === 0 || selectedTypes.includes(type);
          const passCategory = selectedCategories.length === 0 || selectedCategories.includes(category);
          const passCollection = selectedCollections.length === 0 || selectedCollections.includes(collection);

          return passPrice && passType && passCategory && passCollection;
        });

        // Aplicar Sort sobre los que coinciden
        matchingCards.sort((a, b) => {
          const pA = parseFloat(a.dataset.price || "0");
          const pB = parseFloat(b.dataset.price || "0");
          const tA = (a.dataset.title || "").toLowerCase();
          const tB = (b.dataset.title || "").toLowerCase();
          
          if (sortValue === "Precio: Menor a Mayor") return pA - pB;
          if (sortValue === "Precio: Mayor a Menor") return pB - pA;
          if (sortValue === "A - Z") return tA.localeCompare(tB);
          if (sortValue === "Z - A") return tB.localeCompare(tA);
          return 0; // Recomendados
        });

        // Paginación
        const totalPages = Math.max(1, Math.ceil(matchingCards.length / itemsPerPage));
        if (currentPage > totalPages) currentPage = totalPages;

        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        const visibleCards = matchingCards.slice(startIndex, endIndex);

        // Mostrar solo los de esta pagina en el DOM en orden
        visibleCards.forEach(card => {
          card.style.display = "";
          grid.appendChild(card); 
        });

        // Actualizar contador superior si existe y actualizar nav HTML de paginación
        // Disparamos un custom event para que ShopTopBar.astro escuche y actualice el numero
        document.dispatchEvent(new CustomEvent('update-results-count', { detail: matchingCards.length }));

        renderPagination(totalPages, grid);
      });
    };

    const resetFilters = () => {
      if(sortSelect) sortSelect.value = "Recomendados";
      if(priceMin) priceMin.value = "";
      if(priceMax) priceMax.value = "";
      typeCheckboxes.forEach(cb => cb.checked = false);
      categoryCheckboxes.forEach(cb => cb.checked = false);
      collectionCheckboxes.forEach(cb => cb.checked = false);
      filterAndSort(true);
    };

    sortSelect?.addEventListener("change", () => filterAndSort(true));
    applyPriceBtn?.addEventListener("click", () => filterAndSort(true));
    resetBtn?.addEventListener("click", resetFilters);
    typeCheckboxes.forEach(cb => cb.addEventListener("change", () => filterAndSort(true)));
    categoryCheckboxes.forEach(cb => cb.addEventListener("change", () => filterAndSort(true)));
    collectionCheckboxes.forEach(cb => cb.addEventListener("change", () => filterAndSort(true)));
    
    // Ejecutamos inicial si quedaron cargados por cache o hay preselecciones
    filterAndSort(true);
  });
</script>
