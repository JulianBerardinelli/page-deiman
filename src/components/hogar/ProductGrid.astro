---
import ProductCard from '~/components/hogar/ProductCard.astro';
import { Icon } from 'astro-icon/components';

export interface Props {
  products: { id: string; title: string; handle: string; [key: string]: unknown }[];
  fetchError: string | null;
  emptyTitle?: string;
  emptyDescription?: string;
}

const { 
  products, 
  fetchError,
  emptyTitle = "No hay productos",
  emptyDescription = "No encontramos productos en esta sección por el momento. Vuelve más tarde."
} = Astro.props;
---

<!-- Grid -->
{fetchError ? (
  <div class="py-16 bg-red-50/50 text-red-700 rounded-3xl border border-red-100 flex flex-col items-center justify-center text-center max-w-2xl mx-auto">
    <div class="bg-red-100 p-4 rounded-full mb-4">
      <Icon name="tabler:alert-triangle" class="w-10 h-10 text-red-500" />
    </div>
    <h3 class="text-xl font-black mb-2 tracking-tight">Vaya, algo salió mal</h3>
    <p class="text-red-600/80 font-medium">{fetchError}</p> 
  </div>
) : products.length === 0 ? (
  <div class="py-20 bg-white/50 backdrop-blur-sm text-gray-500 rounded-3xl border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-center max-w-3xl mx-auto shadow-sm">
    <div class="bg-slate-100 p-5 rounded-full mb-6">
      <Icon name="tabler:basket-x" class="w-12 h-12 text-gray-400" />
    </div>
    <h3 class="text-2xl font-black mb-3 text-gray-900 tracking-tight">{emptyTitle}</h3>
    <p class="max-w-md text-gray-500 font-medium leading-relaxed">{emptyDescription}</p>
    <a href="/hogar/tienda" class="mt-8 px-6 py-3 bg-gray-900 hover:bg-black text-white rounded-xl font-bold transition-transform hover:-translate-y-0.5 shadow-lg shadow-gray-900/20">
      Volver a la Tienda
    </a>
  </div>
) : (
  <div class="flex flex-col w-full">
    <div class="product-grid grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 xl:gap-8">
      {products.map((p) => (
        <ProductCard product={p} />
      ))}
    </div>

    <!-- HeroUI Style Pagination Component -->
    <div class="mt-12 mb-4 flex justify-center w-full">
      <nav class="inline-flex flex-wrap items-center justify-center gap-1.5 md:gap-2 bg-white/70 backdrop-blur-md p-1.5 md:p-2 rounded-2xl shadow-sm border border-gray-100" aria-label="Paginación de productos">
        
        <!-- Botón Anterior -->
        <button class="flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-400 transition-colors cursor-not-allowed" disabled aria-label="Página anterior">
          <Icon name="tabler:chevron-left" class="w-5 h-5" />
        </button>
        
        <!-- Páginas -->
        <button class="flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-primary text-white font-bold text-sm shadow-[0_4px_14px_0_rgb(0,129,188,0.39)] transition-transform hover:-translate-y-0.5 cursor-pointer" aria-current="page">
          1
        </button>
        <button class="flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-700 hover:bg-gray-100 font-medium text-sm transition-colors cursor-pointer">
          2
        </button>
        <button class="hidden sm:flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-700 hover:bg-gray-100 font-medium text-sm transition-colors cursor-pointer">
          3
        </button>
        
        <!-- Ellipsis (Puntos suspensivos) -->
        <span class="flex items-center justify-center w-7 h-9 text-gray-400 font-bold select-none">
          <Icon name="tabler:dots" class="w-4 h-4" />
        </span>
        
        <button class="flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-700 hover:bg-gray-100 font-medium text-sm transition-colors cursor-pointer">
          8
        </button>

        <!-- Botón Siguiente -->
        <button class="flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-xl bg-transparent text-gray-700 hover:bg-gray-100 transition-colors cursor-pointer" aria-label="Página siguiente">
          <Icon name="tabler:chevron-right" class="w-5 h-5" />
        </button>

      </nav>
    </div>
  </div>
)}
