<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #FF3130;
    --aw-color-secondary: #d00000;
    --aw-color-accent: #0081bc;

    --aw-color-text-heading: #000000;
    --aw-color-text-default: #000000;
    --aw-color-text-muted: rgba(0, 0, 0, 0.66);
    --aw-color-bg-page: #FFFFFF;

    --aw-color-bg-page-dark: #000000;

    ::selection {
      background-color: #FF3130;
      color: #FFFFFF;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #FF3130;
    --aw-color-secondary: #ff6767;
    --aw-color-accent: #000000;

    --aw-color-text-heading: #FFFFFF;
    --aw-color-text-default: #FFFFFF;
    --aw-color-text-muted: rgba(255, 255, 255, 0.66);
    --aw-color-bg-page: #000000;

    ::selection {
      background-color: #FFFFFF;
      color: #000000;
    }
  }

  
  @keyframes gradientText {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-text {
    background: linear-gradient(270deg, #FF3130, #d00000, #ff9292);
    background-size: 600% 600%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientText 6s ease infinite;
  }

  @keyframes fadeToRed {
    0% {
      color: #ffffff;
      filter: drop-shadow(0 0 0 rgb(255, 247, 234));
    }
    100% {
      color: #FF3130; /* Tailwind red-500 */
      filter: drop-shadow(0 0 2px rgb(255, 247, 234)));
    }
  }

  .animate-fade-to-red {
    animation: fadeToRed 1.2s ease-out forwards;
    animation-delay: 0.5s; /* Espera 500ms antes de comenzar */
  }

  /* Animated Background Mappet SVG */
  @keyframes slideBg {
    from {
      background-position: 0px 0px;
    }
    to {
      /* Mueve exactamente 1 ciclo del SVG original para un loop 100% perfecto */
      background-position: -1920px -3115px; 
    }
  }

  .animate-slide-bg {
    animation: slideBg 180s linear infinite;
    will-change: background-position;
  }

</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
