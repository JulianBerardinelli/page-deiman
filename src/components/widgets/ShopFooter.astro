---
import { Icon } from 'astro-icon/components';
import VisaIcon from '~/components/icons/VisaIcon.astro';
import MastercardIcon from '~/components/icons/MastercardIcon.astro';
import AmexIcon from '~/components/icons/AmexIcon.astro';
import ApplePayIcon from '~/components/icons/ApplePayIcon.astro';
import GooglePayIcon from '~/components/icons/GooglePayIcon.astro';
import MercadoPagoIcon from '~/components/icons/MercadoPagoIcon.astro';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 bg-white dark:bg-slate-900 dark:border-slate-800 not-prose']}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300">
    <!-- Top section: Links -->
    <div class="grid grid-cols-12 gap-8 py-8 md:py-12">
      <!-- Brand & Description -->
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-4">
          <a class="inline-block font-bold text-2xl text-primary" href="/hogar">
            Deiman Hogar <span class="text-sm font-normal text-muted ml-1">Shop</span>
          </a>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 max-w-sm">
          Calidad profesional ahora disponible para tus recetas caseras y pequeños emprendimientos. Disfruta de la mejor selección de sabores, colores y sazonadores.
        </p>
        
        <!-- Social Icons in Brand column for Ecommerce -->
        {socialLinks?.length ? (
          <ul class="flex flex-wrap gap-2">
            {socialLinks.map(({ ariaLabel, href, icon }) => (
              <li>
                <a
                  class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2 inline-flex items-center transition-colors"
                  aria-label={ariaLabel}
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                </a>
              </li>
            ))}
          </ul>
        ) : null}
      </div>
      
      <!-- Link Columns -->
      <div class="col-span-12 lg:col-span-8">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-8">
          {links.map(({ title, links }) => (
            <div class="col-span-1">
              <h3 class="dark:text-gray-300 font-semibold mb-4 text-primary text-xs uppercase tracking-wider">{title}</h3>
              {links && Array.isArray(links) && links.length > 0 && (
                <ul class="space-y-3 text-sm">
                  {links.map(({ text, href, ariaLabel }) => (
                    <li>
                      <a
                        class="text-gray-600 hover:text-primary dark:text-gray-400 dark:hover:text-primary transition duration-150 ease-in-out"
                        href={href}
                        aria-label={ariaLabel}
                      >
                        <Fragment set:html={text} />
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Middle section: Payment Methods / Trust badges (Ecommerce specific) -->
    <div class="py-6 border-t border-gray-100 dark:border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3 text-sm text-gray-500">
        <Icon name="tabler:shield-check" class="w-5 h-5 text-green-500" />
        <span>Compra 100% Segura</span>
      </div>
      <div class="flex items-center gap-2 opacity-70 grayscale hover:grayscale-0 transition-all">
        <!-- Payment Methods -->
         <VisaIcon width="40px" height="28px" />
         <MastercardIcon width="40px" height="28px" />
         <AmexIcon width="40px" height="28px" />
         <ApplePayIcon width="40px" height="28px" />
         <GooglePayIcon width="40px" height="28px" />
         <div class="flex items-center justify-center p-1 bg-white rounded-md border border-gray-200" style="width: 40px; height: 28px;">
           <MercadoPagoIcon width="28px" height="20px" class="flex-shrink-0" />
         </div>
      </div>
    </div>

    <!-- Bottom section: Copyright & Legal Links -->
    <div class="md:flex md:items-center md:justify-between py-6 md:py-8 border-t border-gray-100 dark:border-slate-800">
      <div class="text-sm text-gray-500 dark:text-muted mb-4 md:mb-0">
        <Fragment set:html={footNote} />
      </div>

      <div class="text-sm text-gray-500 flex flex-wrap gap-4">
        {secondaryLinks.map(({ text, href }) => (
          <a
            class="hover:text-gray-900 dark:hover:text-white transition duration-150 ease-in-out"
            href={href}
            set:html={text}
          />
        ))}
      </div>
    </div>
  </div>
</footer>
